{
  "name": "back-future",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Що змінилось у науці й історії після твого випуску. Українською мовою.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "npm run test:unit && npm run test:e2e",
    "ci": "npm run lint && npm run typecheck && npm run test:unit && npm run validate:content",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check . && npm run lint:md",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!dist\" \"!test-results\"",
    "validate:content": "tsx scripts/validate-content.ts",
    "coverage:content": "tsx scripts/content-coverage.ts",
    "dump:source-urls": "tsx scripts/dump-source-urls.ts",
    "audit:lighthouse": "CHROME_PATH=$(tsx scripts/find-chrome.ts) lhci autorun --config=./lighthouserc.cjs",
    "posthog:setup": "tsx scripts/posthog-setup.ts",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,astro,json,jsonc,yml,yaml,css}": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write",
      "markdownlint-cli2"
    ]
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@sentry/astro": "^10.52.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "tailwindcss": "^4.3.0",
    "typescript": "5.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "markdownlint-cli2": "^0.22.1",
    "pagefind": "^1.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.1",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "yaml": "^2.8.4",
    "tmp": "^0.2.5"
  }
}
