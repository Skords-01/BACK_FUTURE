{
  "name": "back-future",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Що змінилось у науці й історії після твого випуску. Українською мовою.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check",
    "test": "npm run test:e2e",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check . && npm run lint:md",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"!node_modules\" \"!dist\"",
    "validate:content": "tsx scripts/validate-content.ts",
    "coverage:content": "tsx scripts/content-coverage.ts",
    "audit:lighthouse": "CHROME_PATH=$(tsx scripts/find-chrome.ts) lhci autorun --config=./lighthouserc.cjs",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@astrojs/check": "0.9.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.2",
    "tailwindcss": "^4.2.4",
    "typescript": "5.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-plugin-astro": "^1.7.0",
    "markdownlint-cli2": "^0.18.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.21.0"
  }
}
