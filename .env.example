# Site URL для canonical / OG / sitemap.
PUBLIC_SITE_URL=https://back-future.example.com

# Аналітика (опціонально, без cookies).
# Залиш порожнім — і ніяких трекерів не підвантажиться.
# Підтримуються "plausible", "umami", "posthog". Self-hosted інстанси теж окей.

# --- Plausible ---
# PUBLIC_ANALYTICS_PROVIDER=plausible
# PUBLIC_PLAUSIBLE_DOMAIN=back-future.example.com
# PUBLIC_PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js

# --- Umami ---
# PUBLIC_ANALYTICS_PROVIDER=umami
# PUBLIC_UMAMI_WEBSITE_ID=00000000-0000-0000-0000-000000000000
# PUBLIC_UMAMI_SCRIPT_URL=https://umami.example.com/script.js

# --- PostHog ---
# PUBLIC_ANALYTICS_PROVIDER=posthog
# PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Sentry (опціонально, error tracking).
# Без DSN — інтеграція не підключається взагалі (нульовий runtime).
# DSN — публічний (видно у браузері), тому префікс PUBLIC_* щоб Astro/Vite
# проброcили його у клієнтський бандл (`import.meta.env.PUBLIC_SENTRY_DSN`).
# AUTH_TOKEN/ORG потрібні тільки якщо хочеш завантажувати source maps під час
# білду (CI/Vercel) — тримай їх як sensitive env vars, у клієнтському бандлі їх не повинно бути.
# PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXXX
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=back-future
# SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxx

# Верифікація пошуковців (опціонально). Видно у HTML, не sensitive.
# GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BING_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
