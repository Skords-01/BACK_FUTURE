---
// Перемикач теми: light → dark → system → light.
// Стани:
//   - localStorage["theme"] === "light" — примусово світла
//   - localStorage["theme"] === "dark"  — примусово темна
//   - відсутній ключ                    — system (слідкуємо за prefers-color-scheme)
// Pre-paint скрипт у Base.astro гарантує, що `<html>` має правильний клас
// до першого рендеру, тому FOUC немає.
---

<button
  id="theme-toggle"
  type="button"
  class="border-ink-200 text-ink-700 hover:border-accent-700 hover:text-accent-700 dark:border-ink-700 dark:bg-ink-800 dark:text-ink-200 dark:hover:border-accent-400 dark:hover:text-accent-300 bg-paper-50 inline-flex h-9 w-9 items-center justify-center rounded-full border transition"
  aria-label="Переключити тему"
  data-theme-toggle
>
  <!-- Sun (видимий у темній темі — натискання → light) -->
  <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path
      d="M10 3a1 1 0 011 1v1a1 1 0 11-2 0V4a1 1 0 011-1zm5.66 2.34a1 1 0 010 1.41l-.7.71a1 1 0 11-1.42-1.41l.71-.71a1 1 0 011.41 0zM17 10a1 1 0 110 2h-1a1 1 0 110-2h1zm-1.34 5.66a1 1 0 01-1.41 0l-.71-.71a1 1 0 111.41-1.41l.71.7a1 1 0 010 1.42zM10 15a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zm-5.66-1.34a1 1 0 011.41 1.41l-.7.71a1 1 0 01-1.42-1.41l.71-.71zM5 10a1 1 0 110 2H4a1 1 0 110-2h1zm-.34-5.66a1 1 0 011.41 0l.71.71A1 1 0 015.36 6.46l-.71-.71a1 1 0 010-1.41zM10 6.5a3.5 3.5 0 100 7 3.5 3.5 0 000-7z"
    ></path>
  </svg>
  <!-- Moon (видимий у світлій темі — натискання → dark) -->
  <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
    <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.querySelector("[data-theme-toggle]");
    if (!(btn instanceof HTMLButtonElement)) return;

    const root = document.documentElement;
    const STORAGE_KEY = "theme";
    const media = window.matchMedia("(prefers-color-scheme: dark)");

    /** @returns {"dark"|"light"} */
    function effectiveTheme() {
      return root.classList.contains("dark") ? "dark" : "light";
    }

    /** @returns {"dark"|"light"|"system"} */
    function storedPreference() {
      try {
        const v = window.localStorage.getItem(STORAGE_KEY);
        if (v === "dark" || v === "light") return v;
      } catch {
        // localStorage недоступний — повертаємо system.
      }
      return "system";
    }

    function apply(/** @type {"dark"|"light"|"system"} */ pref) {
      const isDark = pref === "dark" || (pref === "system" && media.matches);
      root.classList.toggle("dark", isDark);
      try {
        if (pref === "system") {
          window.localStorage.removeItem(STORAGE_KEY);
        } else {
          window.localStorage.setItem(STORAGE_KEY, pref);
        }
      } catch {
        // localStorage недоступний — preference у стані тільки в DOM.
      }
      btn.setAttribute(
        "aria-label",
        effectiveTheme() === "dark" ? "Переключити на світлу тему" : "Переключити на темну тему",
      );
      btn.setAttribute("title", btn.getAttribute("aria-label") ?? "");
    }

    btn.addEventListener("click", function () {
      apply(effectiveTheme() === "dark" ? "light" : "dark");
    });

    // Якщо користувач не виставляв preference — реагуємо на зміни system.
    media.addEventListener("change", function () {
      if (storedPreference() === "system") apply("system");
    });

    // Синхронізуємо стан кнопки з поточним класом (вже встановленим pre-paint
    // скриптом у Base.astro). Не перемикаємо клас повторно — це б спричинило
    // миттєвий flash через CSS transitions.
    (function syncButton() {
      const isDark = root.classList.contains("dark");
      btn.setAttribute(
        "aria-label",
        isDark ? "Переключити на світлу тему" : "Переключити на темну тему",
      );
      btn.setAttribute("title", btn.getAttribute("aria-label") ?? "");
    })();
  })();
</script>
