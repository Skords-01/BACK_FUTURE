---
import type { Fact } from "../lib/filterFacts";
import { formatUkShortDate, isoDate } from "../lib/format";
import { factSlug, factUrl } from "../lib/url";
import { SUBJECTS } from "../config/site";

interface Props {
  fact: Fact;
}

const { fact } = Astro.props;
const updatedAt = fact.data.updatedAt;
const detailUrl = factUrl(fact.id);
const slug = factSlug(fact.id);

const subject = SUBJECTS.find((s) => s.id === fact.data.subject);
const mark = subject?.mark ?? "—";
const quote = fact.data.quote;

function serialFromId(id: string): string {
  let h = 0;
  for (let i = 0; i < id.length; i++) {
    h = (h * 31 + id.charCodeAt(i)) >>> 0;
  }
  const n = (h % 999) + 1;
  return String(n).padStart(3, "0");
}
const serial = serialFromId(fact.id);
---

<article
  id={`fact-card-${slug}`}
  class="feature-card shadow-card hover:shadow-card-hover relative isolate grid grid-cols-1 overflow-hidden rounded-3xl border border-[color:var(--card-edge)] bg-[color:var(--card)] transition hover:-translate-y-0.5 lg:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]"
>
  <!-- Text column -->
  <div class="px-6 py-7 sm:px-8 sm:py-9 lg:px-10 lg:py-10">
    <!-- Meta row: № serial · MARK · ★ ВІХА -->
    <div class="fact-meta-row flex flex-wrap items-center gap-2">
      <span class="text-ink-500 dark:text-ink-400 font-mono text-[11px] tracking-wider">
        № {serial}
      </span>
      <span class="text-ink-400 dark:text-ink-600" aria-hidden="true">·</span>
      <span
        class="text-accent-700 dark:text-accent-300 font-display text-[12px] font-semibold tracking-[0.18em] uppercase"
        title={subject?.label ?? "Предмет"}
      >
        {mark}
      </span>
      <span class="text-ink-400 dark:text-ink-600" aria-hidden="true">·</span>
      <span
        class="bg-accent-500 inline-flex items-center rounded-full px-2.5 py-1 font-mono text-[10px] font-semibold tracking-[0.18em] text-white uppercase"
        title="Переломний факт — змінив ширшу картину"
      >
        ★ Віха
      </span>
      {
        fact.data.region === "ukraine" && (
          <span
            class="border-accent-200 bg-accent-50 text-accent-800 dark:border-accent-800 dark:bg-accent-900/30 dark:text-accent-200 inline-flex items-center rounded-full border px-2 py-0.5 font-mono text-[10px] font-medium tracking-wider uppercase"
            title="Український внесок"
          >
            UA
          </span>
        )
      }
    </div>

    <!--
      Інлайн-розшифровка для бейджа ★ Віха. FeatureFactCard рендериться
      лише для `impact === "high"` (див. src/pages/[year].astro), тож текст
      завжди в контексті. На мобільному `title`-tooltip недоступний — без
      цього рядка користувач не зрозуміє маркер.
    -->
    <p
      class="text-ink-500 dark:text-ink-400 mt-2 font-mono text-[10.5px] leading-snug tracking-wide italic"
    >
      ★ Віха — переломний факт, що змінив ширшу картину світу
    </p>

    <h3
      class="font-display text-ink-900 mt-4 text-3xl leading-[1.05] font-extrabold tracking-tight sm:text-4xl"
    >
      {fact.data.title}
    </h3>

    <p class="text-ink-700 mt-4 max-w-prose text-lg leading-relaxed">
      {fact.data.short}
    </p>

    {
      (fact.data.before || fact.data.after) && (
        <dl class="border-ink-200 bg-paper-50 mt-6 grid gap-3 rounded-2xl border border-dashed p-4 sm:grid-cols-[1fr_auto_1fr] sm:items-stretch sm:gap-4 dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]">
          {fact.data.before ? (
            <div>
              <dt class="text-ink-500 dark:text-ink-400 mb-1 font-mono text-[10px] tracking-[0.2em] uppercase">
                Було
              </dt>
              <dd class="text-ink-700 text-sm leading-relaxed">{fact.data.before}</dd>
            </div>
          ) : (
            <div />
          )}
          <div aria-hidden="true" class="text-accent-500 dark:text-accent-400 font-bold">
            <span class="block text-center text-lg sm:hidden">↓</span>
            <span class="hidden self-center text-2xl sm:block">→</span>
          </div>
          {fact.data.after ? (
            <div>
              <dt class="text-accent-700 dark:text-accent-300 mb-1 font-mono text-[10px] tracking-[0.2em] uppercase">
                Стало
              </dt>
              <dd class="text-ink-900 text-sm leading-relaxed">{fact.data.after}</dd>
            </div>
          ) : (
            <div />
          )}
        </dl>
      )
    }

    <div class="mt-6 flex flex-wrap items-center gap-4">
      <a
        href={detailUrl}
        class="text-accent-700 hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200 inline-flex min-h-[44px] items-center gap-1 font-mono text-xs tracking-wider uppercase underline-offset-2 hover:underline"
        aria-label={`Відкрити сторінку факту: ${fact.data.title}`}
      >
        Докладніше →
      </a>
      {
        updatedAt && (
          <time
            datetime={isoDate(updatedAt)}
            class="text-ink-400 dark:text-ink-500 font-mono text-[10px] tracking-wider uppercase tabular-nums"
            title="Дата останнього оновлення цього факту"
          >
            оновл. {formatUkShortDate(updatedAt)}
          </time>
        )
      }
    </div>
  </div>

  <!-- Illustration column -->
  <aside
    class="bg-paper-100 dark:bg-paper-200 relative flex flex-col gap-6 border-t border-[color:var(--card-edge)] px-6 py-7 sm:px-8 lg:border-t-0 lg:border-l lg:px-8 lg:py-10"
    aria-hidden={quote ? undefined : "true"}
  >
    <!-- Oversized subject mark (dominant visual element) -->
    <div class="flex flex-1 items-center justify-center">
      <div class="text-center select-none" aria-hidden="true">
        <span
          class="font-display text-accent-500/90 block text-7xl leading-none font-extrabold tracking-tight sm:text-8xl lg:text-[7rem]"
        >
          {mark}
        </span>
        <span
          class="text-ink-400 dark:text-ink-600 mt-2 block font-mono text-[11px] font-medium tracking-[0.18em] uppercase"
        >
          {subject?.label ?? ""}
        </span>
      </div>
    </div>

    <!-- Quote (if present) -->
    {
      quote && (
        <blockquote class="border-accent-500 border-l-2 pl-4">
          <p class="text-ink-800 dark:text-ink-900 font-display text-sm leading-snug italic">
            «{quote.text}»
          </p>
          <footer class="text-ink-500 dark:text-ink-400 mt-1 font-mono text-[10px] tracking-wider uppercase">
            — {quote.author}
          </footer>
        </blockquote>
      )
    }

    <!-- Year stamp at bottom -->
    <div class="flex items-center gap-3">
      <span
        class="border-ink-300 text-ink-700 dark:border-ink-600 dark:text-ink-400 inline-block rotate-[-2deg] rounded border-2 px-3 py-1 font-mono text-base font-bold tabular-nums"
        aria-label={`Рік події: ${fact.data.yearOfEvent}`}
      >
        {fact.data.yearOfEvent}
      </span>
      <span class="text-ink-500 dark:text-ink-600 font-mono text-[10px] tracking-wider uppercase">
        Подія
      </span>
    </div>
  </aside>
</article>
