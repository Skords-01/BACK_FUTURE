---
import { getCollection } from "astro:content";
import { SITE } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const factsCount = allFacts.length;

function pluralizeFacts(n: number): string {
  const mod10 = n % 10;
  const mod100 = n % 100;
  if (mod10 === 1 && mod100 !== 11) return "факт";
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return "факти";
  return "фактів";
}

const factsLabel = pluralizeFacts(factsCount);

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  // Normalize both sides so a clean URL `/about/` matches `/about` or
  // `/about.html`. We strip the optional `.html` extension and then any
  // trailing slash, leaving a bare path comparable across formats.
  const normalized = href.replace(/\.html$/, "").replace(/\/$/, "");
  const current = path.replace(/\.html$/, "").replace(/\/$/, "");
  return current === normalized;
}

const navLinks = [
  { href: "/timeline/", label: "Хронологія" },
  { href: "/metodologia/", label: "Методологія" },
  { href: "/about/", label: "Про проєкт" },
] as const;
---

<header
  class="border-ink-100 bg-paper-50/80 supports-[backdrop-filter]:bg-paper-50/70 sticky top-0 z-40 border-b backdrop-blur dark:border-[color:var(--card-edge)] dark:bg-[color:var(--paper)]/85 dark:supports-[backdrop-filter]:bg-[color:var(--paper)]/70"
>
  <div class="container-wide relative flex items-center justify-between gap-3 py-4">
    <a
      href="/"
      class="font-display text-ink-900 dark:text-ink-900 flex items-center gap-2 text-lg font-bold tracking-tight"
    >
      {SITE.name}
      <span
        class="bg-accent-50 text-accent-700 dark:bg-accent-900/50 dark:text-accent-200 hidden rounded-full px-2 py-0.5 font-mono text-xs font-medium tabular-nums sm:inline"
        aria-label={`${factsCount} ${factsLabel} у базі`}
        title={`${factsCount} ${factsLabel} у базі`}
      >
        {factsCount}
        {factsLabel}
      </span>
    </a>

    <div class="flex items-center gap-1 sm:gap-3">
      <nav
        id="primary-nav"
        aria-label="Основна навігація"
        data-state="closed"
        class="primary-nav text-ink-600 dark:text-ink-800 text-sm"
      >
        <ul class="primary-nav__list">
          {
            navLinks.map((link) => (
              <li>
                <a
                  class:list={[
                    "primary-nav__link hover:bg-ink-100 dark:hover:bg-ink-200 rounded-full px-3 py-1.5 transition",
                    isActive(link.href) &&
                      "bg-ink-100 text-ink-900 dark:text-ink-900 font-medium dark:bg-[color:var(--card)]",
                  ]}
                  href={link.href}
                  aria-current={isActive(link.href) ? "page" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <ThemeToggle />

      <button
        type="button"
        id="primary-nav-toggle"
        class="border-ink-200 text-ink-700 hover:border-accent-700 hover:text-accent-700 dark:text-ink-700 dark:hover:border-accent-400 dark:hover:text-accent-300 bg-paper-50 inline-flex h-11 w-11 items-center justify-center rounded-full border transition sm:hidden dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
        aria-controls="primary-nav"
        aria-expanded="false"
        aria-label="Відкрити меню"
      >
        <svg
          data-icon="open"
          class="h-5 w-5"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M3 6h14"></path>
          <path d="M3 10h14"></path>
          <path d="M3 14h14"></path>
        </svg>
        <svg
          data-icon="close"
          class="hidden h-5 w-5"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M5 5l10 10"></path>
          <path d="M15 5L5 15"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Mobile-first: на ≤sm нав за замовчуванням схований; кнопка-бургер відкриває
     панель, прибита до низу хедера. На ≥sm нав завжди inline і ігнорує
     data-state, щоб layout не «стрибав» при ресайзі з відкритим мобільним
     меню. */
  .primary-nav {
    display: none;
  }
  .primary-nav[data-state="open"] {
    display: block;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 39;
    background: var(--paper);
    border-top: 1px solid var(--card-edge);
    box-shadow: var(--shadow);
    padding: 0.75rem 1.25rem 1rem;
    max-height: calc(100dvh - 4rem);
    overflow-y: auto;
  }
  .primary-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .primary-nav__link {
    display: flex;
    align-items: center;
    min-height: 44px; /* WCAG 2.5.5 / Apple HIG touch target */
  }

  @media (min-width: 640px) {
    .primary-nav,
    .primary-nav[data-state="open"] {
      display: block;
      position: static;
      background: transparent;
      border-top: none;
      box-shadow: none;
      padding: 0;
      max-height: none;
      overflow: visible;
    }
    .primary-nav__list {
      flex-direction: row;
      align-items: center;
      gap: 0.25rem;
    }
    .primary-nav__link {
      min-height: 0;
    }
  }
</style>

<script is:inline>
  (function () {
    const nav = document.getElementById("primary-nav");
    const toggle = document.getElementById("primary-nav-toggle");
    if (!(nav instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) return;

    const iconOpen = toggle.querySelector('[data-icon="open"]');
    const iconClose = toggle.querySelector('[data-icon="close"]');

    function setState(open) {
      nav.dataset.state = open ? "open" : "closed";
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Закрити меню" : "Відкрити меню");
      if (iconOpen instanceof SVGElement) iconOpen.classList.toggle("hidden", open);
      if (iconClose instanceof SVGElement) iconClose.classList.toggle("hidden", !open);
    }

    toggle.addEventListener("click", function () {
      setState(nav.dataset.state !== "open");
    });

    // Закриваємо при кліку поза хедером — крім кліків на сам toggle (його
    // ми вже опрацювали вище). Перевіряємо, чи клік стався в межах хедера.
    document.addEventListener("click", function (e) {
      if (nav.dataset.state !== "open") return;
      const header = nav.closest("header");
      if (header && e.target instanceof Node && header.contains(e.target)) return;
      setState(false);
    });

    // Esc закриває меню; повертаємо фокус на toggle для KB-користувачів.
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && nav.dataset.state === "open") {
        setState(false);
        toggle.focus();
      }
    });

    // При переході на ≥sm скидаємо стан, щоб користувач не лишився з
    // прихованим панельним nav-ом, який чомусь зберіг `data-state="open"`.
    const mq = window.matchMedia("(min-width: 640px)");
    mq.addEventListener("change", function (e) {
      if (e.matches) setState(false);
    });
  })();
</script>
