---
import { getCollection } from "astro:content";
import { SITE } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const factsCount = allFacts.length;

function pluralizeFacts(n: number): string {
  const mod10 = n % 10;
  const mod100 = n % 100;
  if (mod10 === 1 && mod100 !== 11) return "факт";
  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return "факти";
  return "фактів";
}

const factsLabel = pluralizeFacts(factsCount);

const path = Astro.url.pathname;
function isActive(href: string): boolean {
  // Normalize both sides so a clean URL `/about/` matches `/about` or
  // `/about.html`. We strip the optional `.html` extension and then any
  // trailing slash, leaving a bare path comparable across formats.
  const normalized = href.replace(/\.html$/, "").replace(/\/$/, "");
  const current = path.replace(/\.html$/, "").replace(/\/$/, "");
  return current === normalized;
}
---

<header
  class="border-ink-100 dark:border-ink-700 bg-paper-50/80 dark:bg-ink-900/80 supports-[backdrop-filter]:bg-paper-50/70 dark:supports-[backdrop-filter]:bg-ink-900/70 sticky top-0 z-40 border-b backdrop-blur"
>
  <div class="container-wide flex items-center justify-between gap-3 py-4">
    <a
      href="/"
      class="font-display text-ink-900 dark:text-ink-50 flex items-center gap-2 text-lg font-bold tracking-tight"
    >
      {SITE.name}
      <span
        class="bg-accent-50 text-accent-700 dark:bg-accent-900/50 dark:text-accent-200 hidden rounded-full px-2 py-0.5 font-mono text-xs font-medium tabular-nums sm:inline"
        aria-label={`${factsCount} ${factsLabel} у базі`}
        title={`${factsCount} ${factsLabel} у базі`}
      >
        {factsCount}
        {factsLabel}
      </span>
    </a>
    <nav
      aria-label="Основна навігація"
      class="text-ink-600 dark:text-ink-800 flex items-center gap-1 text-sm sm:gap-3"
    >
      <a
        class:list={[
          "hover:bg-ink-100 dark:hover:bg-ink-200 rounded-full px-3 py-1.5 transition",
          isActive("/metodologia/") &&
            "bg-ink-100 text-ink-900 dark:bg-ink-200 dark:text-ink-900 font-medium",
        ]}
        href="/metodologia/"
        aria-current={isActive("/metodologia/") ? "page" : undefined}
      >
        Методологія
      </a>
      <a
        class:list={[
          "hover:bg-ink-100 dark:hover:bg-ink-200 rounded-full px-3 py-1.5 transition",
          isActive("/about/") &&
            "bg-ink-100 text-ink-900 dark:bg-ink-200 dark:text-ink-900 font-medium",
        ]}
        href="/about/"
        aria-current={isActive("/about/") ? "page" : undefined}
      >
        Про проєкт
      </a>
      <ThemeToggle />
    </nav>
  </div>
</header>
