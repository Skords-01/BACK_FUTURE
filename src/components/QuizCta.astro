---
import { plural, factsWord } from "../lib/plurals";

interface Props {
  factsCount: number;
}
const { factsCount } = Astro.props;

// Use the verb "new fact / new facts / new facts" form here — the noun phrase
// is grammatically tied to the adjective "новий" / "нові" / "нових".
const learnedLabel = plural(factsCount, "uk", {
  one: "новий факт",
  few: "нові факти",
  many: "нових фактів",
  other: "нових фактів",
});
---

<section class="container-wide py-12">
  <div
    class="flex flex-col items-center gap-6 rounded-sm border-2 border-[color:var(--ink)] bg-[color:var(--card)] px-6 py-10 text-center sm:px-12"
  >
    <p class="font-mono text-[11px] tracking-[0.18em] text-[color:var(--muted)] uppercase">
      Перевір себе
    </p>
    <h2
      class="font-display text-[clamp(1.5rem,4vw,2.5rem)] leading-tight font-extrabold tracking-[-0.03em] text-[color:var(--ink)]"
    >
      Вгадай, коли це сталось?
    </h2>
    <p class="max-w-md text-base text-[color:var(--ink-2)]">
      Ти щойно дізнався {factsCount}
      {learnedLabel}. Тепер перевір, чи зможеш вгадати рік кожної події — 5 питань, нові факти
      щоразу.
    </p>
    <a
      href="/quiz/"
      class="font-display inline-flex items-center gap-2 rounded-sm bg-[color:var(--accent)] px-8 py-4 text-base font-semibold text-white transition hover:opacity-90"
    >
      Почати квіз →
    </a>
    <p class="font-mono text-xs text-[color:var(--muted)]">
      {
        factsCount > 0
          ? `${factsCount} ${factsWord(factsCount)} у пулі`
          : `165 ${factsWord(165)} у пулі`
      } · нові питання щоразу
    </p>
  </div>
</section>
