---
/**
 * Horizontal cream-paper timeline 1991 → SITE.yearMax.
 *
 * Redesigned to match the mockup:
 * - Taller inner padding so dots/marker have breathing room
 * - Dots: 10px with `border: 2px solid var(--paper)` — look "placed" on the axis
 * - High-impact dots: 14px, amber/hl glow ring
 * - Axis: 2px height, rounded, ink-6/card-edge colour
 * - Major ticks (every 5y) vs minor ticks (every year)
 * - Marker: vertical line with circle cap + label above
 * - CSS ::after tooltip on hover (hidden on touch devices)
 * - Era bands: dashed right-border separators, active band highlights
 * - Mobile: overflow-x scroll with snap, touch-action: pan-x
 */
import { ERAS } from "../lib/eras";
import { SITE } from "../config/site";
import type { Fact } from "../lib/filterFacts";

interface Props {
  selectedYear?: number;
  facts?: readonly Fact[];
  compact?: boolean;
}

const { selectedYear, facts = [], compact = false } = Astro.props;

const yearMin = SITE.yearMin;
const yearMax = SITE.yearMax;
const span = Math.max(1, yearMax - yearMin);

const pct = (y: number): number => ((y - yearMin + 0.5) / (span + 1)) * 100;

// Ticks: major every 5 years, minor every year
const allYears: number[] = [];
for (let y = yearMin; y <= yearMax; y++) allYears.push(y);
const majorTicks = allYears.filter((y) => y === yearMin || y === yearMax || y % 5 === 0);

type Dot = {
  year: number;
  left: number;
  high: boolean;
  title: string;
  href: string;
};
const dots: Dot[] = facts
  .filter((f) => !f.data.draft)
  .map((f) => ({
    year: f.data.yearOfEvent,
    left: pct(f.data.yearOfEvent),
    high: f.data.impact === "high",
    title: `${f.data.yearOfEvent}: ${f.data.title}`,
    href: `/${f.data.yearOfEvent}/`,
  }));

const markerLeft = selectedYear ? pct(selectedYear) : null;

// Which era is the selected year in?
const activeEraId = selectedYear
  ? ERAS.find((e) => selectedYear >= e.yearStart && selectedYear <= e.yearEnd)?.id
  : null;
---

<figure
  class="timeline-figure not-prose mt-6 mb-2 sm:mt-8"
  aria-label={`Шкала років від ${yearMin} до ${yearMax}`}
>
  <!-- Outer scroll wrapper -->
  <div class="tl-scroll" tabindex="0" role="region" aria-label="Таймлайн (горизонтальний скрол)">
    <div class="tl-inner" style={`--span: ${span + 1};`}>
      <!-- Era band labels -->
      {
        !compact && (
          <ol class="tl-era-labels" aria-hidden="true">
            {ERAS.map((e) => {
              const start = ((e.yearStart - yearMin) / (span + 1)) * 100;
              const width = Math.max(0, ((e.yearEnd + 1 - yearMin) / (span + 1)) * 100 - start);
              return (
                <li
                  class={`tl-era-label${e.id === activeEraId ? " is-active" : ""}`}
                  style={`left: ${start}%; width: ${width}%;`}
                  title={`${e.label} (${e.yearStart}–${e.yearEnd})`}
                >
                  {e.label.split(" ")[0]}
                </li>
              );
            })}
          </ol>
        )
      }

      <!-- Era bands: dashed separators -->
      <div class="tl-bands" aria-hidden="true">
        {
          ERAS.map((e) => {
            const start = ((e.yearStart - yearMin) / (span + 1)) * 100;
            const width = Math.max(0, ((e.yearEnd + 1 - yearMin) / (span + 1)) * 100 - start);
            return (
              <div
                class={`tl-band era-${e.id}${e.id === activeEraId ? " is-active" : ""}`}
                style={`left: ${start}%; width: ${width}%;`}
              />
            );
          })
        }
      </div>

      <!-- Axis -->
      <div class="tl-axis-wrap" aria-hidden="true">
        <div class="tl-axis">
          <!-- Minor ticks (every year, no label) -->
          {
            allYears.map(
              (y) => !majorTicks.includes(y) && <div class="tl-tick" style={`left: ${pct(y)}%;`} />,
            )
          }
          <!-- Major ticks (every 5y, with label) -->
          {
            majorTicks.map((y) => (
              <div class="tl-tick tl-tick--major" style={`left: ${pct(y)}%;`}>
                <span class="tl-tick-label">{y}</span>
              </div>
            ))
          }

          <!-- Fact dots ON the axis -->
          {
            dots.map((d) => (
              <a
                href={d.href}
                class={`tl-dot${d.high ? " tl-dot--high" : ""}`}
                style={`left: ${d.left}%;`}
                data-tip={d.title}
                aria-label={d.title}
              >
                <span class="sr-only">{d.title}</span>
              </a>
            ))
          }

          <!-- Selected year marker -->
          {
            markerLeft !== null && (
              <div class="tl-marker" style={`left: ${markerLeft}%;`} aria-hidden="true">
                <span class="tl-marker-line" />
                <span class="tl-marker-cap" />
                <span class="tl-marker-label">ВИПУСК {selectedYear}</span>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Legend -->
  <figcaption class="tl-legend" aria-hidden="true">
    <span>
      <span class="tl-swatch"></span>
      усі факти
    </span>
    <span>
      <span class="tl-swatch tl-swatch--high"></span>
      переломні
    </span>
    {
      selectedYear && (
        <span>
          <span class="tl-swatch tl-swatch--year" />
          твій рік
        </span>
      )
    }
  </figcaption>
</figure>

<style>
  /* ---- Scroll container ---- */
  .tl-scroll {
    position: relative;
    overflow-x: auto;
    overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior-x: contain;
    touch-action: pan-x;
    scrollbar-width: thin;
    scrollbar-color: var(--card-edge) transparent;
    scroll-snap-type: x proximity;
    padding-bottom: 4px;
  }
  .tl-scroll:focus-visible {
    outline: 2px solid var(--accent-500);
    outline-offset: 3px;
    border-radius: 10px;
  }
  .tl-scroll::-webkit-scrollbar {
    height: 4px;
  }
  .tl-scroll::-webkit-scrollbar-thumb {
    background: var(--card-edge);
    border-radius: 4px;
  }

  /* ---- Inner sizing ---- */
  .tl-inner {
    position: relative;
    min-width: 760px;
    /* top space: era labels (24px) + gap (8px) = 32px
       bottom space: axis (2px) + ticks (16px) + labels (18px) = 36px */
    padding: 32px 0 36px;
  }

  /* ---- Era labels (above bands) ---- */
  .tl-era-labels {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 24px;
    pointer-events: none;
    user-select: none;
  }
  .tl-era-label {
    position: absolute;
    top: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-400, #8f7a54);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding-left: 6px;
    transition: color 0.15s;
  }
  .tl-era-label.is-active {
    color: var(--accent-500, #b9381a);
    font-weight: 600;
  }

  /* ---- Era bands ---- */
  .tl-bands {
    position: absolute;
    /* align with the axis: top = era-labels-height + gap = 32px, bottom = 36px */
    top: 32px;
    bottom: 36px;
    left: 0;
    right: 0;
    pointer-events: none;
  }
  .tl-band {
    position: absolute;
    top: 0;
    bottom: 0;
    border-right: 1px dashed var(--rule);
    transition: background 0.2s;
  }
  .tl-band:last-child {
    border-right: none;
  }
  .tl-band.is-active {
    background: color-mix(in srgb, var(--accent-500) 8%, transparent);
  }

  /* ---- Axis wrapper (positions axis in the middle of padding) ---- */
  .tl-axis-wrap {
    position: relative;
  }
  .tl-axis {
    position: relative;
    height: 2px;
    background: var(--card-edge);
    border-radius: 2px;
    overflow: visible;
  }

  /* ---- Ticks ---- */
  .tl-tick {
    position: absolute;
    top: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 8px;
    background: var(--ink-300, #6b5938);
    margin-top: -4px;
  }
  .tl-tick--major {
    width: 1.5px;
    height: 14px;
    background: var(--ink-500, #b09a72);
    margin-top: -7px;
  }
  .tl-tick-label {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-500, #b09a72);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    user-select: none;
  }

  /* ---- Fact dots ---- */
  .tl-dot {
    position: absolute;
    top: 50%;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ink-600, #c4b898);
    border: 2px solid var(--paper, #f3ecdc);
    transform: translate(-50%, -50%);
    z-index: 2;
    cursor: pointer;
    transition:
      transform 0.15s,
      background 0.15s;
    display: block;
  }
  .tl-dot:hover {
    transform: translate(-50%, -50%) scale(1.5);
    background: var(--accent-500, #b9381a);
    z-index: 4;
  }
  .tl-dot--high {
    width: 14px;
    height: 14px;
    background: var(--hl, #d97706);
    border-color: var(--paper, #f3ecdc);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--hl) 28%, transparent);
    z-index: 3;
  }
  .tl-dot--high:hover {
    background: var(--hl, #d97706);
    transform: translate(-50%, -50%) scale(1.35);
  }

  /* Tooltip via CSS ::after — hidden on touch */
  .tl-dot[data-tip]::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink-900, #1a1813);
    color: var(--paper, #f3ecdc);
    padding: 6px 10px;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1.4;
    white-space: normal;
    text-align: center;
    max-width: 240px;
    min-width: 120px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.12s;
    z-index: 10;
  }
  .tl-dot:hover[data-tip]::after,
  .tl-dot:focus-visible[data-tip]::after {
    opacity: 1;
  }
  @media (hover: none) {
    .tl-dot[data-tip]::after {
      display: none;
    }
  }

  /* ---- Marker ---- */
  .tl-marker {
    position: absolute;
    top: -28px;
    bottom: -10px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 5;
    width: 0;
  }
  .tl-marker-line {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    background: var(--accent-500, #b9381a);
    border-radius: 2px;
  }
  .tl-marker-cap {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent-500, #b9381a);
    border: 2px solid var(--paper, #f3ecdc);
  }
  .tl-marker-label {
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--paper, #f3ecdc);
    background: var(--accent-500, #b9381a);
    padding: 2px 8px;
    border-radius: 999px;
    white-space: nowrap;
  }

  /* ---- Legend ---- */
  .tl-legend {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 12px;
    padding-left: 2px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-500, #b09a72);
    user-select: none;
  }
  .tl-legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .tl-swatch {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ink-600, #c4b898);
    border: 2px solid var(--paper, #f3ecdc);
    flex-shrink: 0;
  }
  .tl-swatch--high {
    width: 12px;
    height: 12px;
    background: var(--hl, #d97706);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--hl) 28%, transparent);
  }
  .tl-swatch--year {
    background: var(--accent-500, #b9381a);
    border-color: var(--paper, #f3ecdc);
  }

  /* ---- Dark mode overrides ---- */
  :global(html.dark) .tl-band.is-active {
    background: color-mix(in srgb, var(--accent-500) 12%, transparent);
  }
  :global(html.dark) .tl-dot {
    border-color: var(--paper, #2a2218);
  }
  :global(html.dark) .tl-dot--high {
    border-color: var(--paper, #2a2218);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--hl) 32%, transparent);
  }
  :global(html.dark) .tl-marker-cap,
  :global(html.dark) .tl-swatch,
  :global(html.dark) .tl-swatch--year {
    border-color: var(--paper, #2a2218);
  }
  :global(html.dark) .tl-dot[data-tip]::after {
    background: var(--ink-900, #f0e8d2);
    color: var(--paper, #2a2218);
  }

  /* ---- Mobile sizing ---- */
  @media (max-width: 640px) {
    .tl-dot {
      width: 12px;
      height: 12px;
    }
    .tl-dot--high {
      width: 16px;
      height: 16px;
    }
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .tl-dot {
      transition: none;
    }
  }
</style>
