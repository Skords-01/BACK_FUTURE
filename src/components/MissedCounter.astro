---
// MissedCounter — shows how many discoveries the user missed + era name.
// Updated reactively via year:change event.
import { ERAS } from "../lib/eras";

interface Props {
  defaultYear?: number;
  factsFromYear: Record<number, number>; // yearOfGraduation → count of facts since then
}
const { defaultYear = 2012, factsFromYear } = Astro.props;
const currentYear = new Date().getFullYear();
const defaultCount = factsFromYear[defaultYear] ?? 0;
const defaultYearsAgo = currentYear - defaultYear;

const erasForClient = ERAS.map((e) => ({
  id: e.id,
  name: e.name,
  color: e.color,
  yearStart: e.yearStart,
  yearEnd: e.yearEnd,
}));

function pluralize(n: number): string {
  const m10 = n % 10;
  const m100 = n % 100;
  if (m10 === 1 && m100 !== 11) return "рік";
  if (m10 >= 2 && m10 <= 4 && (m100 < 12 || m100 > 14)) return "роки";
  return "років";
}
---

<div
  class="mb-6 flex flex-col items-center gap-4 border-l-4 border-[color:var(--accent)] bg-[color:var(--paper-2)] px-5 py-5 sm:flex-row sm:gap-7 sm:px-7 sm:py-6"
  id="missed-counter"
  data-facts-map={JSON.stringify(factsFromYear)}
  data-eras={JSON.stringify(erasForClient)}
  data-year-max={currentYear}
>
  <div
    class="font-display text-[clamp(3rem,12vw,6rem)] leading-none font-extrabold tracking-tight text-[color:var(--accent)] tabular-nums"
    id="counter-num"
  >
    {defaultCount}
  </div>
  <div class="text-lg leading-snug text-[color:var(--ink-2)]">
    <strong class="text-[color:var(--ink)]">відкриттів</strong> ти пропустив<br />
    за <em class="text-[color:var(--accent)] italic" id="counter-years">{defaultYearsAgo}</em>
    <span id="counter-years-word">{pluralize(defaultYearsAgo)}</span> після
    <span id="counter-base-year">{defaultYear}</span>-го.
    <span
      class="mt-1.5 block font-mono text-xs tracking-wider"
      id="counter-era"
      style="color: var(--era-color, var(--muted))"></span>
  </div>
</div>

<script>
  type EraEntry = { id: number; name: string; color: string; yearStart: number; yearEnd: number };
  const container = document.getElementById("missed-counter");
  let erasData: EraEntry[] = [];
  try {
    erasData = JSON.parse(container?.dataset.eras ?? "[]");
  } catch {}

  function eraOf(year: number): EraEntry {
    return (
      erasData.find((e) => year >= e.yearStart && year <= e.yearEnd) ??
      erasData[erasData.length - 1]!
    );
  }

  function pluralize(n: number): string {
    const m10 = n % 10;
    const m100 = n % 100;
    if (m10 === 1 && m100 !== 11) return "рік";
    if (m10 >= 2 && m10 <= 4 && (m100 < 12 || m100 > 14)) return "роки";
    return "років";
  }

  const numEl = document.getElementById("counter-num");
  const yearsEl = document.getElementById("counter-years");
  const yearsWordEl = document.getElementById("counter-years-word");
  const baseYearEl = document.getElementById("counter-base-year");
  const eraEl = document.getElementById("counter-era");

  let factsMap: Record<number, number> = {};
  try {
    factsMap = JSON.parse(container?.dataset.factsMap ?? "{}");
  } catch {
    // ignore parse errors
  }
  const yearMax = parseInt(container?.dataset.yearMax ?? "2026", 10);

  document.addEventListener("year:change", (e) => {
    const year = (e as CustomEvent<{ year: number }>).detail.year;
    const count = factsMap[year] ?? 0;
    const yearsAgo = yearMax - year;
    const era = eraOf(year);

    if (numEl) numEl.textContent = String(count);
    if (yearsEl) yearsEl.textContent = String(yearsAgo);
    if (yearsWordEl) yearsWordEl.textContent = pluralize(yearsAgo);
    if (baseYearEl) baseYearEl.textContent = String(year);
    if (eraEl) {
      eraEl.textContent = `· епоха «${era.name}»`;
      eraEl.style.setProperty("--era-color", era.color);
    }
  });
</script>
