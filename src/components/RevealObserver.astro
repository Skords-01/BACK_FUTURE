---
/*
 * RevealObserver — глобальний IntersectionObserver, що шукає всі `[data-reveal]`
 * на сторінці і додає їм клас `.is-visible`, як тільки вони перетинають viewport.
 * Стилі для `[data-reveal]` лежать у `src/styles/global.css` (opacity 0 →
 * translateY(8px) → fade-in). prefers-reduced-motion обробляється там же.
 *
 * Чому окремий компонент: щоб логіка не дублювалась між сторінками
 * (`/[year]`, `/subject/[id]`, `/era/[slug]`, `/timeline`). Підключений у
 * Base.astro, тож автоматично працює всюди — нові сторінки нічого не потребують.
 *
 * No-op гілка: якщо на сторінці немає `[data-reveal]`, observer створюється,
 * нічого не спостерігає і одразу збирається GC. Якщо `IntersectionObserver`
 * недоступний (старий Safari, MSEdge), всім елементам одразу додається
 * `.is-visible` — без анімації, але видимі.
 */
---

<script is:inline>
  (function () {
    var nodes = document.querySelectorAll("[data-reveal]");
    if (nodes.length === 0) return;
    if (!("IntersectionObserver" in window)) {
      nodes.forEach(function (el) {
        el.classList.add("is-visible");
      });
      return;
    }
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -32px 0px" },
    );
    nodes.forEach(function (el) {
      observer.observe(el);
    });
  })();
</script>
