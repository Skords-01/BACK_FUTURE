---
import { SITE } from "../config/site";
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-100 bg-white">
  <div
    class="container-wide flex flex-col items-start justify-between gap-3 py-8 text-sm text-ink-500 sm:flex-row sm:items-center"
  >
    <div>
      © {year}
      {SITE.name}. Зроблено в Україні.
    </div>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <a class="hover:text-ink-900" href="/metodologia.html">Методологія</a>
      <a class="hover:text-ink-900" href="/about.html">Про проєкт</a>
      <a class="hover:text-ink-900" href={SITE.repoUrl}>GitHub</a>
    </div>
  </div>
</footer>
