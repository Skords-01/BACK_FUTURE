---
import { SITE } from "../config/site";
const year = new Date().getFullYear();
---

<footer class="border-ink-100 dark:border-ink-700 dark:bg-ink-900 border-t bg-white">
  <div
    class="container-wide text-ink-500 dark:text-ink-400 flex flex-col items-start justify-between gap-3 py-8 text-sm sm:flex-row sm:items-center"
  >
    <div>
      © {year}
      {SITE.name}. Зроблено в Україні.
    </div>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <a class="hover:text-ink-900 dark:hover:text-ink-100" href="/metodologia/">Методологія</a>
      <a class="hover:text-ink-900 dark:hover:text-ink-100" href="/about/">Про проєкт</a>
      <a class="hover:text-ink-900 dark:hover:text-ink-100" href={SITE.repoUrl}>GitHub</a>
    </div>
  </div>
</footer>
