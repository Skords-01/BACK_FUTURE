---
import { SITE } from "../config/site";
import LangSwitcher from "./LangSwitcher.astro";
import { DEFAULT_LOCALE, type Locale } from "../i18n/ui";
import { getT, toLocale } from "../i18n/t";

const year = new Date().getFullYear();
const path = Astro.url.pathname;
const enPrefix = "/en";
const isEnPath = path === enPrefix || path.startsWith(`${enPrefix}/`);
const astroLocale = toLocale(Astro.currentLocale);
const locale: Locale = astroLocale === "en" || isEnPath ? "en" : DEFAULT_LOCALE;
const t = getT(locale);
const prefix = locale === "en" ? enPrefix : "";

// Локалезалежний підпис «бренд / навігація / підтримка». Tagline беремо
// зі словника на EN-боці (UK-tagline вже сидить у `SITE.tagline`).
const footerTagline = locale === "en" ? t("site.tagline") : SITE.tagline;
const supportTitle = locale === "en" ? "Support" : "Підтримати";
const supportBody =
  locale === "en"
    ? "The project is free and ad-free. If you like it — buy us a coffee."
    : "Проєкт безкоштовний і без реклами. Якщо подобається — пригости кавою.";
const monoLabel = locale === "en" ? "monobank · jar →" : "monobank · банка →";
const githubAria =
  locale === "en" ? "GitHub — opens in a new tab" : "GitHub — відкривається в новій вкладці";
const footerNavAria = locale === "en" ? "Site navigation" : "Навігація сайту";
const sergeantAria =
  locale === "en"
    ? "SERGEANT_GROUP — the brand that unites the project's products"
    : "SERGEANT_GROUP — бренд, що об'єднує продукти проєкту";
---

<footer class="border-t border-[color:var(--rule)] bg-[color:var(--paper-2)]">
  <div class="container-wide py-12">
    <div class="grid gap-10 sm:grid-cols-3">
      <!-- Brand column -->
      <div>
        <p class="font-display text-xl font-bold tracking-tight text-[color:var(--ink)]">
          {SITE.name}
        </p>
        <p class="mt-2 text-sm leading-relaxed text-[color:var(--ink-2)]">
          {footerTagline}
        </p>

        <div
          class="mt-5 flex items-center gap-3 rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] p-3"
          aria-label={sergeantAria}
        >
          <img
            src="/brand/sergeant-group.svg"
            alt=""
            width="36"
            height="36"
            loading="lazy"
            decoding="async"
            class="h-9 w-9 shrink-0 rounded-[6px]"
          />
          <div class="leading-tight">
            <p class="font-mono text-[11px] tracking-[0.18em] text-[color:var(--muted)] uppercase">
              {t("footer.part_of")}
            </p>
            <p class="font-display text-sm font-bold tracking-[0.04em] text-[color:var(--ink)]">
              SERGEANT_GROUP
            </p>
          </div>
        </div>

        <p class="mt-4 font-mono text-xs text-[color:var(--muted)]">
          © {year} · {t("footer.made_in_ua")}
        </p>

        <div class="mt-5">
          <LangSwitcher variant="footer" />
        </div>
      </div>

      <!-- Project column -->
      <nav aria-label={footerNavAria}>
        <h2
          class="mb-3 font-mono text-[10px] tracking-[0.18em] text-[color:var(--muted)] uppercase"
        >
          {t("footer.nav")}
        </h2>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href={`${prefix}/timeline/`}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              {t("nav.timeline")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/quiz/`}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              {t("nav.quiz")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/all/`}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              {t("nav.all")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/metodologia/`}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              {t("nav.metodologia")}
            </a>
          </li>
          <li>
            <a
              href={`${prefix}/about/`}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              {t("nav.about")}
            </a>
          </li>
          <li>
            <a
              href="/rss.xml"
              class="inline-flex items-center gap-1.5 text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"
                ></path>
              </svg>
              RSS
            </a>
          </li>
          <li>
            <a
              href={SITE.repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={githubAria}
              class="text-[color:var(--ink-2)] underline-offset-2 transition hover:text-[color:var(--accent)] hover:underline"
            >
              GitHub <span aria-hidden="true">↗</span>
            </a>
          </li>
        </ul>
      </nav>

      <!-- Support column -->
      <div>
        <h2
          class="mb-3 font-mono text-[10px] tracking-[0.18em] text-[color:var(--muted)] uppercase"
        >
          {supportTitle}
        </h2>
        <p class="mb-4 text-sm leading-relaxed text-[color:var(--ink-2)]">
          {supportBody}
        </p>
        {
          SITE.monobankJarUrl && (
            <a
              href={SITE.monobankJarUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-sm border border-[color:var(--accent)] bg-transparent px-4 py-2.5 font-mono text-sm font-semibold text-[color:var(--accent)] transition hover:bg-[color:var(--accent)] hover:text-white"
            >
              {monoLabel}
            </a>
          )
        }
      </div>
    </div>
  </div>
</footer>
