---
import { SITE } from "../config/site";
const year = new Date().getFullYear();
---

<footer
  class="border-ink-100 border-t bg-white dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
>
  <div
    class="container-wide text-ink-500 dark:text-ink-400 flex flex-col items-start justify-between gap-3 py-8 text-sm sm:flex-row sm:items-center"
  >
    <div>
      © {year}
      {SITE.name}. Зроблено в Україні.
    </div>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <a class="hover:text-ink-900 dark:hover:text-ink-900" href="/metodologia/">Методологія</a>
      <a class="hover:text-ink-900 dark:hover:text-ink-900" href="/about/">Про проєкт</a>
      <a class="hover:text-ink-900 dark:hover:text-ink-900" href={SITE.repoUrl}>GitHub</a>
    </div>
  </div>
</footer>
