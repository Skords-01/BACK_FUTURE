---
// YearNav — three-card year navigator: ← prev | змінити рік | next →
import { SITE } from "../config/site";

interface Props {
  year: number;
}
const { year } = Astro.props;

const prev = year > SITE.yearMin ? year - 1 : null;
const next = year < SITE.yearMax ? year + 1 : null;
---

<nav aria-label="Навігація між роками" class="ynav container-wide">
  <!-- Prev year -->
  {
    prev ? (
      <a href={`/${prev}/`} class="ynav__b">
        <span class="ynav__sub">← Попередній</span>
        <span class="ynav__y">{prev}</span>
      </a>
    ) : (
      <div class="ynav__b ynav__b--disabled" aria-hidden="true">
        <span class="ynav__sub">← Попередній</span>
        <span class="ynav__y" style="opacity:0.2">
          —
        </span>
      </div>
    )
  }

  <!-- Change year -->
  <a href="/" class="ynav__b ynav__b--ctr" aria-label="Змінити рік">
    <span class="ynav__dot" aria-hidden="true"></span>
    <span class="ynav__sub">Змінити рік</span>
  </a>

  <!-- Next year -->
  {
    next ? (
      <a href={`/${next}/`} class="ynav__b ynav__b--r">
        <span class="ynav__sub">Наступний →</span>
        <span class="ynav__y">{next}</span>
      </a>
    ) : (
      <div class="ynav__b ynav__b--r ynav__b--disabled" aria-hidden="true">
        <span class="ynav__sub">Наступний →</span>
        <span class="ynav__y" style="opacity:0.2">
          —
        </span>
      </div>
    )
  }
</nav>

<style>
  .ynav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 12px;
    margin-top: 56px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    padding-bottom: 48px;
  }

  .ynav__b {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
    padding: 24px 28px;
    background: var(--card);
    border: 1px solid var(--card-edge);
    border-radius: 4px;
    transition:
      border-color 0.15s,
      transform 0.15s;
    text-align: left;
    text-decoration: none;
  }

  .ynav__b:not(.ynav__b--disabled):hover,
  .ynav__b:not(.ynav__b--disabled):focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .ynav__b--r {
    align-items: flex-end;
    text-align: right;
  }

  .ynav__b--ctr {
    align-items: center;
    padding: 24px 36px;
    min-width: 100px;
  }

  .ynav__b--disabled {
    opacity: 0.4;
    cursor: default;
  }

  .ynav__sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .ynav__y {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--accent);
    font-variant-numeric: tabular-nums;
  }

  .ynav__dot {
    display: block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--accent);
    margin-bottom: 4px;
  }

  @media (max-width: 480px) {
    .ynav {
      grid-template-columns: 1fr;
    }
    .ynav__b--r {
      align-items: flex-start;
      text-align: left;
    }
    .ynav__b--ctr {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ynav__b {
      transition: none;
    }
  }
</style>
