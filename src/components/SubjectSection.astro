---
import FactCard from "./FactCard.astro";
import type { Fact } from "../lib/filterFacts";
import type { SubjectId } from "../config/site";

interface Props {
  subjectId: SubjectId;
  emoji: string;
  label: string;
  items: Fact[];
}

const { subjectId, emoji, label, items } = Astro.props;
---

<section id={`subject-${subjectId}`} class="mt-12 scroll-mt-20">
  <header class="mb-5 flex items-baseline gap-3">
    <span class="text-3xl" aria-hidden="true">{emoji}</span>
    <h2
      class="font-display text-ink-900 dark:text-ink-50 text-2xl font-extrabold tracking-tight sm:text-3xl"
    >
      {label}
    </h2>
    <span class="text-ink-500 dark:text-ink-400 ml-auto font-mono text-xs tabular-nums">
      {items.length}
      {items.length === 1 ? "оновлення" : "оновлень"}
    </span>
  </header>
  <div class="grid gap-4">
    {items.map((f) => <FactCard fact={f} />)}
  </div>
</section>
