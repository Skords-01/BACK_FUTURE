---
import { SITE } from "../config/site";
import { updatesCount } from "../lib/plurals";

interface Props {
  year: number;
  factsCount: number;
}

const { year, factsCount } = Astro.props;

const shareUrl = new URL(`/${year}/`, SITE.defaultUrl);
const url = shareUrl.toString();
const messageBase =
  factsCount > 0
    ? `Випустився ${year}-го. З тих пір пропустив ${factsCount} ${updatesCount(factsCount)} у науці й історії.`
    : `Як змінились наука й історія від випуску ${year}-го?`;
const message = `${messageBase} ${SITE.tagline} — ${SITE.name}.`;

const shareEncoded = encodeURIComponent(message);
const urlEncoded = encodeURIComponent(url);

// Preview metadata — mirrors what Telegram / X / FB will scrape from <head>.
const previewHost = shareUrl.host.replace(/^www\./, "");
const previewTitle = `Випуск ${year} — ${SITE.name}`;
const previewDescription = messageBase;
const previewImage = new URL(`/og/${year}.png`, SITE.defaultUrl).toString();

const targets = [
  {
    id: "telegram",
    label: "Telegram",
    href: `https://t.me/share/url?url=${urlEncoded}&text=${shareEncoded}`,
  },
  {
    id: "twitter",
    label: "X / Twitter",
    href: `https://twitter.com/intent/tweet?url=${urlEncoded}&text=${shareEncoded}`,
  },
  {
    id: "facebook",
    label: "Facebook",
    href: `https://www.facebook.com/sharer/sharer.php?u=${urlEncoded}`,
  },
];
---

<section class="container-prose mt-12" aria-labelledby="share-heading">
  <div
    class="border-ink-100 bg-paper-50 rounded-3xl border p-6 sm:p-8 dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
  >
    <h2
      id="share-heading"
      class="font-display text-ink-900 text-lg font-bold tracking-tight sm:text-xl"
    >
      Поділись цим випуском
    </h2>
    <p class="text-ink-600 mt-2 text-sm">
      Зі знайомих теж випускники {year}-го? Поділись цим роком.
    </p>

    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Відкрити сторінку ${year}-го у новій вкладці (превʼю того, як вона виглядатиме при шерингу)`}
      class="border-ink-200 hover:border-accent-700 dark:border-ink-700 dark:bg-ink-900 group mt-5 block overflow-hidden rounded-2xl border bg-white transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-current"
    >
      <div class="bg-paper-100 dark:bg-ink-800 aspect-[1200/630] w-full overflow-hidden">
        <img
          src={previewImage}
          alt={`Превʼю Open Graph: ${previewTitle}`}
          loading="lazy"
          decoding="async"
          width="1200"
          height="630"
          class="h-full w-full object-cover"
        />
      </div>
      <div class="border-ink-100 dark:border-ink-700 border-t px-4 py-3 sm:px-5">
        <p class="text-ink-500 dark:text-ink-400 font-mono text-[11px] tracking-widest uppercase">
          {previewHost}
        </p>
        <p
          class="font-display text-ink-900 group-hover:text-accent-700 dark:group-hover:text-accent-300 mt-1 text-base font-bold tracking-tight transition-colors"
        >
          {previewTitle}
        </p>
        <p class="text-ink-600 mt-1 line-clamp-2 text-sm">
          {previewDescription}
        </p>
      </div>
    </a>

    <div
      id="share-buttons"
      class="mt-5 flex flex-wrap gap-2"
      data-share-url={url}
      data-share-text={message}
    >
      {
        targets.map((t) => (
          <a
            href={t.href}
            target="_blank"
            rel="noopener noreferrer"
            data-share-target={t.id}
            class="border-ink-200 hover:border-accent-700 hover:text-accent-700 text-ink-700 dark:hover:border-accent-400 dark:hover:text-accent-300 inline-flex min-h-11 items-center gap-2 rounded-full border bg-white px-4 py-2.5 text-sm font-medium transition dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
          >
            <span aria-hidden="true">↗</span>
            {t.label}
          </a>
        ))
      }
      <button
        id="share-copy-btn"
        type="button"
        class="border-ink-200 hover:border-accent-700 hover:text-accent-700 text-ink-700 dark:hover:border-accent-400 dark:hover:text-accent-300 inline-flex min-h-11 items-center gap-2 rounded-full border bg-white px-4 py-2.5 text-sm font-medium transition dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
      >
        <span aria-hidden="true">⎘</span>
        <span data-state="idle" class="transition-colors">Скопіювати посилання</span>
      </button>
      <button
        id="share-native-btn"
        type="button"
        hidden
        class="border-ink-200 hover:border-accent-700 hover:text-accent-700 text-ink-700 dark:hover:border-accent-400 dark:hover:text-accent-300 inline-flex min-h-11 items-center gap-2 rounded-full border bg-white px-4 py-2.5 text-sm font-medium transition dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
      >
        <span aria-hidden="true">↗</span>
        Поділитись…
      </button>
      <a
        href={`/share/${year}/`}
        data-share-target="poster"
        class="border-ink-200 hover:border-accent-700 hover:text-accent-700 text-ink-700 dark:hover:border-accent-400 dark:hover:text-accent-300 inline-flex min-h-11 items-center gap-2 rounded-full border bg-white px-4 py-2.5 text-sm font-medium transition dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]"
        aria-label={`Завантажити постер року ${year} для Stories`}
      >
        <span aria-hidden="true">⬇</span>
        Завантажити постер
      </a>
    </div>

    <p
      id="share-status"
      class="text-ink-500 dark:text-ink-400 mt-3 hidden text-sm"
      role="status"
      aria-live="polite"
    >
    </p>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.getElementById("share-buttons");
    if (!root) return;
    const url = root.dataset.shareUrl ?? "";
    const text = root.dataset.shareText ?? "";

    function track(event, props) {
      try {
        var ph = window.posthog;
        if (ph && typeof ph.capture === "function") ph.capture(event, props);
      } catch {
        /* analytics never breaks UI */
      }
    }

    // Network share buttons (Telegram / X / Facebook). Click is captured but
    // the link still navigates (target="_blank"); we only fire `share_clicked`
    // since outbound success cannot be confirmed for window.open targets.
    root.querySelectorAll("a[data-share-target]").forEach(function (a) {
      a.addEventListener(
        "click",
        function () {
          track("share_clicked", { target: a.dataset.shareTarget });
        },
        { passive: true },
      );
    });

    const status = document.getElementById("share-status");
    function showStatus(msg) {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove("hidden");
      window.setTimeout(function () {
        if (status.textContent === msg) {
          status.classList.add("hidden");
        }
      }, 2500);
    }

    const copyBtn = document.getElementById("share-copy-btn");
    if (copyBtn instanceof HTMLButtonElement) {
      const labelSpan = copyBtn.querySelector("[data-state]");
      copyBtn.addEventListener("click", function () {
        track("share_clicked", { target: "copy" });
        if (!navigator.clipboard || !navigator.clipboard.writeText) {
          showStatus("Скопіюй вручну: " + url);
          return;
        }
        navigator.clipboard
          .writeText(url)
          .then(function () {
            if (labelSpan instanceof HTMLElement) {
              labelSpan.textContent = "Скопійовано";
            }
            showStatus("Посилання скопійовано в буфер обміну.");
            track("share_succeeded", { target: "copy" });
            window.setTimeout(function () {
              if (labelSpan instanceof HTMLElement) {
                labelSpan.textContent = "Скопіювати посилання";
              }
            }, 2000);
          })
          .catch(function () {
            showStatus("Не вдалось скопіювати. Спробуй вручну: " + url);
          });
      });
    }

    const nativeBtn = document.getElementById("share-native-btn");
    if (
      nativeBtn instanceof HTMLButtonElement &&
      typeof navigator !== "undefined" &&
      typeof navigator.share === "function"
    ) {
      nativeBtn.hidden = false;
      nativeBtn.addEventListener("click", function () {
        track("share_clicked", { target: "native" });
        navigator
          .share({ title: document.title, text: text, url: url })
          .then(function () {
            track("share_succeeded", { target: "native" });
          })
          .catch(function () {
            // User cancelled or share failed; no UI noise.
          });
      });
    }
  })();
</script>
