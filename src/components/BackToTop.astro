---
// BackToTop — floating "↑" button, appears after scrolling 300px.
---

<button id="back-to-top" type="button" aria-label="На початок сторінки" hidden> ↑ </button>

<style>
  #back-to-top {
    position: fixed;
    bottom: 28px;
    right: 24px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--card-edge);
    background: var(--card);
    color: var(--accent-500, #b9381a);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    z-index: 200;
    box-shadow: 0 2px 10px color-mix(in srgb, var(--ink) 12%, transparent);
    transition:
      border-color 0.15s,
      transform 0.15s,
      opacity 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #back-to-top:hover {
    border-color: var(--accent-500, #b9381a);
    transform: translateY(-3px);
  }
  #back-to-top:focus-visible {
    outline: 2px solid var(--accent-500, #b9381a);
    outline-offset: 2px;
  }
  #back-to-top[hidden] {
    display: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #back-to-top {
      transition: none;
    }
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById("back-to-top");
    if (!btn) return;
    var noMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    function onScroll() {
      btn.hidden = window.scrollY < 300;
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    btn.addEventListener("click", function () {
      window.scrollTo({ top: 0, behavior: noMotion ? "instant" : "smooth" });
    });
    onScroll();
  })();
</script>
