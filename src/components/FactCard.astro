---
import { render } from "astro:content";
import type { Fact } from "../lib/filterFacts";
import { topicById } from "../lib/topics";

interface Props {
  fact: Fact;
}

const { fact } = Astro.props;
const { Content } = await render(fact);
const topic = fact.data.topic ? topicById(fact.data.topic) : null;
const comparison = fact.data.comparison;
---

<article
  id={fact.id}
  class="group border-ink-100 shadow-card hover:border-ink-200 hover:shadow-card-hover rounded-3xl border bg-white p-5 transition hover:-translate-y-0.5 sm:p-7"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-display text-ink-900 text-xl leading-snug font-bold sm:text-2xl">
      {fact.data.title}
    </h3>
    <span
      class="bg-accent-50 text-accent-700 shrink-0 rounded-full px-3 py-1 font-mono text-xs font-medium tabular-nums"
    >
      {fact.data.yearOfEvent}
    </span>
  </div>

  {
    topic && (
      <p class="text-ink-500 mt-2 text-xs">
        <span class="text-ink-400 mr-1 font-mono tracking-wider uppercase">Тема:</span>
        <a class="hover:text-ink-900 underline decoration-dotted" href={`/temy.html#${topic.id}`}>
          {topic.label}
        </a>
      </p>
    )
  }

  <p class="text-ink-700 mt-3 text-base leading-relaxed">{fact.data.short}</p>

  {
    comparison && (
      <div class="border-ink-100 bg-paper-50 mt-4 grid gap-3 rounded-2xl border p-4 sm:grid-cols-2 sm:gap-4 sm:p-5">
        <div>
          <div class="text-ink-400 mb-1 text-[0.65rem] font-semibold tracking-widest uppercase">
            У підручнику
          </div>
          <p class="text-ink-700 text-sm leading-relaxed">{comparison.then}</p>
        </div>
        <div class="border-ink-100 sm:border-l sm:pl-4">
          <div class="text-accent-700 mb-1 text-[0.65rem] font-semibold tracking-widest uppercase">
            Зараз
          </div>
          <p class="text-ink-800 text-sm leading-relaxed">{comparison.now}</p>
        </div>
      </div>
    )
  }

  <details class="group/details mt-4">
    <summary
      class="text-accent-700 hover:text-accent-800 inline-flex cursor-pointer items-center gap-1 text-sm font-medium select-none [&::-webkit-details-marker]:hidden"
    >
      <span class="group-open/details:hidden">Докладніше</span>
      <span class="hidden group-open/details:inline">Згорнути</span>
      <svg
        class="h-4 w-4 transition group-open/details:rotate-180"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
          clip-rule="evenodd"></path>
      </svg>
    </summary>

    <div
      class="prose prose-ink prose-headings:font-display prose-a:text-accent-700 text-ink-800 mt-4 max-w-none"
    >
      <Content />
    </div>

    {
      fact.data.sources.length > 0 && (
        <div class="border-ink-100 text-ink-500 mt-4 border-t pt-3 text-xs">
          <div class="text-ink-400 mb-1 font-medium tracking-wider uppercase">Джерела</div>
          <ul class="space-y-1">
            {fact.data.sources.map((s) => (
              <li>
                <a
                  class="hover:text-ink-900"
                  href={s.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {s.title} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </details>
</article>
