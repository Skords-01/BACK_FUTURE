---
import { render } from "astro:content";
import type { Fact } from "../lib/filterFacts";

interface Props {
  fact: Fact;
}

const { fact } = Astro.props;
const { Content } = await render(fact);
---

<article
  class="group rounded-3xl border border-ink-100 bg-white p-5 shadow-card transition hover:-translate-y-0.5 hover:border-ink-200 hover:shadow-card-hover sm:p-7"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-display text-xl font-bold leading-snug text-ink-900 sm:text-2xl">
      {fact.data.title}
    </h3>
    <span
      class="shrink-0 rounded-full bg-accent-50 px-3 py-1 font-mono text-xs font-medium tabular-nums text-accent-700"
    >
      {fact.data.yearOfEvent}
    </span>
  </div>

  <p class="mt-3 text-base leading-relaxed text-ink-700">{fact.data.short}</p>

  <details class="group/details mt-4">
    <summary
      class="inline-flex cursor-pointer select-none items-center gap-1 text-sm font-medium text-accent-700 hover:text-accent-800 [&::-webkit-details-marker]:hidden"
    >
      <span class="group-open/details:hidden">Докладніше</span>
      <span class="hidden group-open/details:inline">Згорнути</span>
      <svg
        class="h-4 w-4 transition group-open/details:rotate-180"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
          clip-rule="evenodd"></path>
      </svg>
    </summary>

    <div
      class="prose prose-ink prose-headings:font-display prose-a:text-accent-700 mt-4 max-w-none text-ink-800"
    >
      <Content />
    </div>

    {
      fact.data.sources.length > 0 && (
        <div class="mt-4 border-t border-ink-100 pt-3 text-xs text-ink-500">
          <div class="mb-1 font-medium uppercase tracking-wider text-ink-400">Джерела</div>
          <ul class="space-y-1">
            {fact.data.sources.map((s) => (
              <li>
                <a
                  class="hover:text-ink-900"
                  href={s.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {s.title} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </details>
</article>
