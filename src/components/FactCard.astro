---
import { render } from "astro:content";

import type { Fact } from "../lib/filterFacts";
import { formatUkShortDate, isoDate } from "../lib/format";

interface Props {
  fact: Fact;
}

const { fact } = Astro.props;
const { Content } = await render(fact);
const updatedAt = fact.data.updatedAt;
---

<article
  class="group border-ink-100 shadow-card hover:border-ink-200 hover:shadow-card-hover dark:border-ink-700 dark:bg-ink-800 dark:hover:border-ink-600 rounded-3xl border bg-white p-5 transition hover:-translate-y-0.5 sm:p-7"
>
  <div class="flex items-start justify-between gap-4">
    <h3
      class="font-display text-ink-900 dark:text-ink-50 text-xl leading-snug font-bold sm:text-2xl"
    >
      {fact.data.title}
    </h3>
    <div class="flex shrink-0 flex-col items-end gap-1">
      <div class="flex items-center gap-1.5">
        {
          fact.data.region === "ukraine" && (
            <span
              class="border-accent-200 bg-accent-50 text-accent-800 dark:border-accent-800 dark:bg-accent-900/30 dark:text-accent-200 inline-flex items-center gap-1 rounded-full border px-2 py-1 text-xs font-medium"
              title="Український внесок"
            >
              <span aria-hidden="true">🇺🇦</span>
              <span>Україна</span>
            </span>
          )
        }
        <span
          class="bg-accent-50 text-accent-700 dark:bg-accent-900/40 dark:text-accent-200 rounded-full px-3 py-1 font-mono text-xs font-medium tabular-nums"
        >
          {fact.data.yearOfEvent}
        </span>
      </div>
      {
        updatedAt && (
          <time
            datetime={isoDate(updatedAt)}
            class="text-ink-400 dark:text-ink-500 inline-flex items-center gap-1 text-[11px] font-medium tabular-nums"
            title="Дата останнього оновлення цього факту"
          >
            <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M15.312 11.424a5.5 5.5 0 01-9.201 2.466l-.312-.311h2.433a.75.75 0 000-1.5H3.989a.75.75 0 00-.75.75v4.242a.75.75 0 001.5 0v-2.43l.31.31a7 7 0 0011.712-3.138.75.75 0 00-1.449-.39zm1.23-3.723a.75.75 0 00.219-.53V2.929a.75.75 0 00-1.5 0V5.36l-.31-.31A7 7 0 003.239 8.188a.75.75 0 101.448.389A5.5 5.5 0 0113.89 6.11l.311.31h-2.432a.75.75 0 000 1.5h4.243a.75.75 0 00.53-.219z"
                clip-rule="evenodd"
              />
            </svg>
            <span>оновл. {formatUkShortDate(updatedAt)}</span>
          </time>
        )
      }
    </div>
  </div>

  <p class="text-ink-700 dark:text-ink-200 mt-3 text-base leading-relaxed">{fact.data.short}</p>

  {
    (fact.data.before || fact.data.after) && (
      <dl class="border-ink-100 bg-ink-50/40 dark:border-ink-700 dark:bg-ink-900/40 mt-4 grid gap-3 rounded-2xl border p-4 sm:grid-cols-2 sm:gap-4">
        {fact.data.before && (
          <div>
            <dt class="text-ink-400 dark:text-ink-500 text-xs font-medium tracking-wider uppercase">
              Було
            </dt>
            <dd class="text-ink-700 dark:text-ink-300 mt-1 text-sm leading-relaxed">
              {fact.data.before}
            </dd>
          </div>
        )}
        {fact.data.after && (
          <div>
            <dt class="text-accent-700 dark:text-accent-300 text-xs font-medium tracking-wider uppercase">
              Стало
            </dt>
            <dd class="text-ink-800 dark:text-ink-100 mt-1 text-sm leading-relaxed">
              {fact.data.after}
            </dd>
          </div>
        )}
      </dl>
    )
  }

  <details class="group/details mt-4">
    <summary
      class="text-accent-700 hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200 inline-flex cursor-pointer items-center gap-1 text-sm font-medium select-none [&::-webkit-details-marker]:hidden"
    >
      <span class="group-open/details:hidden">Докладніше</span>
      <span class="hidden group-open/details:inline">Згорнути</span>
      <svg
        class="h-4 w-4 transition group-open/details:rotate-180"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          fill-rule="evenodd"
          d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z"
          clip-rule="evenodd"></path>
      </svg>
    </summary>

    <div
      class="prose prose-ink prose-headings:font-display prose-a:text-accent-700 dark:prose-invert dark:prose-a:text-accent-300 text-ink-800 dark:text-ink-200 mt-4 max-w-none"
    >
      <Content />
    </div>

    {
      fact.data.sources.length > 0 && (
        <div class="border-ink-100 text-ink-500 dark:border-ink-700 dark:text-ink-400 mt-4 border-t pt-3 text-xs">
          <div class="text-ink-400 dark:text-ink-500 mb-1 font-medium tracking-wider uppercase">
            Джерела
          </div>
          <ul class="space-y-1">
            {fact.data.sources.map((s) => (
              <li>
                <a
                  class="hover:text-ink-900 dark:hover:text-ink-100"
                  href={s.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  {s.title} ↗
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </details>
</article>
