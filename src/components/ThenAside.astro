---
// ThenAside — paper snapshot of the graduation year: president, exchange rate,
// hit song, gadget, etc. Styled like a torn calendar page.
// Falls back to the nearest available epoch year if the exact year is absent.
import { getCollection } from "astro:content";

interface Props {
  year: number;
}
const { year } = Astro.props;

const epochEntries = await getCollection("epoch");

const sorted = epochEntries.slice().sort((a, b) => {
  const da = Math.abs(a.data.year - year);
  const db = Math.abs(b.data.year - year);
  return da - db || a.data.year - b.data.year;
});
const entry = sorted[0];
const items = entry?.data.items ?? [];
const displayYear = entry?.data.year ?? year;

// Ukrainian ordinal suffix for display year (2012 → «2012-й»)
function ordinal(y: number): string {
  return `${y}-й`;
}
---

{
  items.length > 0 && (
    <aside class="then container-wide mt-0 mb-0 py-8" aria-label={`Контекст ${displayYear} року`}>
      <div class="then__inner">
        <div class="then__head">
          <span class="then__year">{ordinal(displayYear)}</span>
          <span class="then__sub">
            контекст · епіграф епохи
            {displayYear !== year && <span class="ml-2 opacity-60">(дані {displayYear} р.)</span>}
          </span>
        </div>
        <dl class="then__grid">
          {items.map((item) => (
            <div class="then__item">
              <dt>{item.k}</dt>
              <dd>{item.v}</dd>
            </div>
          ))}
        </dl>
      </div>
    </aside>
  )
}

<style>
  .then__inner {
    position: relative;
    padding: 28px;
    background: var(--paper-2);
    border: 1px solid var(--card-edge);
    border-radius: 4px;
  }

  /* Decorative perforated-tape strip across the top edge */
  .then__inner::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 32px;
    width: 80px;
    height: 16px;
    background: repeating-linear-gradient(90deg, var(--accent) 0 8px, transparent 8px 16px);
    opacity: 0.35;
  }

  .then__head {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 14px;
    border-bottom: 1px dashed var(--card-edge);
  }

  .then__year {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 32px;
    color: var(--accent);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .then__sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .then__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px 28px;
    margin: 0;
  }

  @media (max-width: 639px) {
    .then__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .then__item dt {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }

  .then__item dd {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 17px;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
    line-height: 1.25;
  }
</style>
