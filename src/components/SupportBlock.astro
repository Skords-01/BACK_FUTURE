---
import { SITE } from "../config/site";

const hasJar = SITE.monobankJarUrl.length > 0;
const hasCoffee = SITE.buyMeACoffeeUrl.length > 0;
---

<aside
  class="container-prose border-ink-100 from-accent-50 dark:from-accent-900/30 dark:to-ink-800 mt-16 rounded-3xl border bg-gradient-to-br to-white p-7 sm:p-10 dark:border-[color:var(--card-edge)]"
>
  <h2 class="font-display text-ink-900 text-2xl font-extrabold sm:text-3xl">
    Сподобалось? Підтримай проєкт
  </h2>
  <p class="text-ink-700 mt-2">
    {SITE.name} — некомерційний просвітницький проєкт. Без підписок і paywall. Якщо хочеш, щоб з'являлось
    більше фактів — кинь на каву.
  </p>

  <div class="mt-5 flex flex-wrap gap-3" id="support-buttons">
    {
      hasJar ? (
        <a
          class="btn"
          href={SITE.monobankJarUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-support-provider="monobank"
        >
          Банка Monobank
        </a>
      ) : (
        <span class="btn-ghost cursor-default opacity-50" aria-disabled="true">
          Банка Monobank — незабаром
        </span>
      )
    }
    {
      hasCoffee && (
        <a
          class="btn-ghost"
          href={SITE.buyMeACoffeeUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-support-provider="buymeacoffee"
        >
          Buy me a coffee
        </a>
      )
    }
  </div>
</aside>

<script>
  import { EVENTS, track } from "../lib/analytics";

  document
    .querySelectorAll<HTMLAnchorElement>("#support-buttons [data-support-provider]")
    .forEach((a) => {
      a.addEventListener(
        "click",
        () => {
          track(EVENTS.supportClicked, { provider: a.dataset.supportProvider ?? null });
        },
        { passive: true },
      );
    });
</script>
