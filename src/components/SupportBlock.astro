---
import { SITE } from "../config/site";

const hasJar = SITE.monobankJarUrl.length > 0;
const hasCoffee = SITE.buyMeACoffeeUrl.length > 0;
---

<aside
  class="container-prose mt-16 rounded-3xl border border-ink-100 bg-gradient-to-br from-accent-50 to-white p-7 sm:p-10"
>
  <h2 class="font-display text-2xl font-extrabold text-ink-900 sm:text-3xl">
    Сподобалось? Підтримай проєкт
  </h2>
  <p class="mt-2 text-ink-700">
    {SITE.name} — некомерційний просвітницький проєкт. Без підписок і paywall. Якщо хочеш, щоб з'являлось
    більше фактів — кинь на каву.
  </p>

  <div class="mt-5 flex flex-wrap gap-3">
    {
      hasJar ? (
        <a class="btn" href={SITE.monobankJarUrl} target="_blank" rel="noopener noreferrer">
          Банка Monobank
        </a>
      ) : (
        <span class="btn-ghost cursor-default opacity-60">Банка Monobank — скоро</span>
      )
    }
    {
      hasCoffee && (
        <a class="btn-ghost" href={SITE.buyMeACoffeeUrl} target="_blank" rel="noopener noreferrer">
          Buy me a coffee
        </a>
      )
    }
  </div>
</aside>
