---
import Base from "../layouts/Base.astro";
import SubjectSection from "../components/SubjectSection.astro";
import SupportBlock from "../components/SupportBlock.astro";
import ShareBlock from "../components/ShareBlock.astro";
import YearInput from "../components/YearInput.astro";
import { getCollection } from "astro:content";
import { factsForYear, groupBySubject } from "../lib/filterFacts";
import { eraForGraduationYear, eraById } from "../lib/eras";
import { SITE } from "../config/site";

export async function getStaticPaths() {
  const years: { params: { year: string } }[] = [];
  for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
    years.push({ params: { year: String(y) } });
  }
  return years;
}

const { year: yearStr } = Astro.params;
const year = Number(yearStr);
if (!Number.isInteger(year) || year < SITE.yearMin || year > SITE.yearMax) {
  return Astro.redirect("/");
}

const allFacts = await getCollection("facts");
const matched = factsForYear(allFacts, year);
const groups = groupBySubject(matched);
const era = eraById(eraForGraduationYear(year));

const totalCount = matched.length;

const description = `Якщо ти випустився ${year}-го — ось що змінилось у науці й історії після того, як ти закрив підручник. ${SITE.name}.`;
const ogImage = new URL(`/og/${year}.svg`, SITE.defaultUrl).toString();

const neighborYears = [year - 5, year - 1, year + 1, year + 5].filter(
  (y) => y >= SITE.yearMin && y <= SITE.yearMax && y !== year,
);
const issueUrl = `${SITE.repoUrl}/issues/new?title=${encodeURIComponent(`Факт під випуск ${year}`)}`;

// Усі year-сторінки регенеряться разом при кожному build — використовуємо
// build-time дату як `datePublished`/`dateModified`. Для трекінгу свіжості
// окремих фактів на сторінці буде поле `updatedAt` (PR #2.3).
const buildDate = new Date().toISOString();
const homeUrl = `${SITE.defaultUrl}/`;
const yearCanonical = new URL(Astro.url.pathname, SITE.defaultUrl).toString();
const articleHeadline =
  totalCount > 0
    ? `Випуск ${year}: ${totalCount} ${totalCount === 1 ? "оновлення" : "оновлень"} після випускного`
    : `Випуск ${year}: ${era.label}`;

const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleHeadline,
  description,
  image: ogImage,
  datePublished: buildDate,
  dateModified: buildDate,
  inLanguage: "uk",
  author: {
    "@type": "Organization",
    name: SITE.author,
    url: SITE.defaultUrl,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.defaultUrl,
  },
  mainEntityOfPage: yearCanonical,
};

const breadcrumbsLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Головна",
      item: homeUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `Випуск ${year}`,
      item: yearCanonical,
    },
  ],
};
---

<Base
  title={`Випуск ${year}`}
  description={description}
  ogImage={ogImage}
  jsonLd={[articleLd, breadcrumbsLd]}
>
  <section class="ruled-hero">
    <div class="container-prose pt-12 pb-12 sm:pt-16">
      <nav aria-label="Хлібні крихти" class="text-ink-500 text-sm">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li>
            <a
              href="/"
              class="hover:text-ink-900 underline-offset-2 hover:underline"
              aria-label="На головну"
            >
              Головна
            </a>
          </li>
          <li aria-hidden="true" class="text-ink-300">›</li>
          <li>
            <span class="text-ink-700 font-medium" aria-current="page">Випуск {year}</span>
          </li>
          <li aria-hidden="true" class="text-ink-300 ml-2">·</li>
          <li>
            <a
              href="/"
              class="hover:text-ink-900 inline-flex items-center gap-1 underline-offset-2 hover:underline"
            >
              ← Інший рік
            </a>
          </li>
        </ol>
      </nav>

      <p
        class="text-accent-700 mt-4 flex flex-wrap items-center gap-2 text-sm font-medium tracking-widest"
      >
        <span
          class="bg-accent-50 text-accent-700 rounded-full px-3 py-1 font-mono text-xs tabular-nums"
          >ВИПУСК {year}</span
        >
        <span class="text-ink-500 font-sans text-xs uppercase">·</span>
        <span class="text-ink-600 text-xs uppercase">{era.label}</span>
      </p>
      <h1
        class="font-display text-ink-900 mt-3 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-5xl"
      >
        {
          totalCount > 0
            ? `Ти пропустив ${totalCount} ${totalCount === 1 ? "оновлення" : "оновлень"}`
            : "Тут поки тихо"
        }
      </h1>
      <p class="text-ink-700 mt-4 max-w-prose text-lg">{era.summary}</p>
    </div>
  </section>

  {
    groups.length > 0 ? (
      <section class="container-prose">
        {groups.map((g) => (
          <SubjectSection emoji={g.emoji} label={g.label} items={g.items} />
        ))}
      </section>
    ) : (
      <section class="container-prose mt-12">
        <div class="border-ink-200 text-ink-700 rounded-3xl border border-dashed bg-white p-8 text-center">
          <p class="font-display text-ink-900 text-xl font-bold">Поки що для цього року тихо.</p>
          <p class="text-ink-600 mt-2 text-base">
            Ми постійно додаємо факти. Спробуй сусідній рік — ера програм та сама, контент скоріш за
            все підходить:
          </p>
          <div class="mt-5 flex flex-wrap justify-center gap-2">
            {neighborYears.map((y) => (
              <a
                href={`/${y}.html`}
                class="border-ink-200 text-ink-700 hover:border-accent-700 hover:text-accent-700 inline-flex items-center rounded-full border bg-white px-4 py-1.5 font-mono text-sm font-medium tabular-nums transition"
              >
                {y}
              </a>
            ))}
          </div>
          <p class="text-ink-500 mt-5 text-sm">
            Хочеш, щоб ми додали факт під цей рік?{" "}
            <a
              href={issueUrl}
              class="text-accent-700 hover:text-accent-800 underline-offset-2 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Запропонуй у GitHub
            </a>
          </p>
        </div>
      </section>
    )
  }

  <ShareBlock year={year} factsCount={totalCount} />

  <SupportBlock />

  <section class="container-prose mt-16">
    <h2 class="font-display text-ink-900 text-xl font-bold">Спробуй інший рік</h2>
    <div class="mt-4">
      <YearInput defaultYear={year} size="md" />
    </div>
  </section>
</Base>
