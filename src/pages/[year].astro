---
import Base from "../layouts/Base.astro";
import SupportBlock from "../components/SupportBlock.astro";
import ShareBlock from "../components/ShareBlock.astro";
import YearInput from "../components/YearInput.astro";
import FactCard from "../components/FactCard.astro";
import { getCollection } from "astro:content";
import { factsForYear, groupBySubject, pickFallbackYears, sampleFacts } from "../lib/filterFacts";
import { ERAS, eraForGraduationYear, eraById } from "../lib/eras";
import { SITE, SUBJECTS } from "../config/site";
import { eraUrl } from "../lib/url";

export async function getStaticPaths() {
  const years: { params: { year: string } }[] = [];
  for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
    years.push({ params: { year: String(y) } });
  }
  return years;
}

const { year: yearStr } = Astro.params;
const year = Number(yearStr);
if (!Number.isInteger(year) || year < SITE.yearMin || year > SITE.yearMax) {
  return Astro.redirect("/");
}

const allFacts = await getCollection("facts");
const matched = factsForYear(allFacts, year);
const groups = groupBySubject(matched);
const era = eraById(eraForGraduationYear(year));

const totalCount = matched.length;

const description = `Якщо ти випустився ${year}-го — ось що змінилось у науці й історії після того, як ти закрив підручник. ${SITE.name}.`;
const ogImage = new URL(`/og/${year}.png`, SITE.defaultUrl).toString();

const fallbackYears =
  totalCount === 0
    ? pickFallbackYears(year, allFacts)
        .filter((f) => f.year !== year)
        .slice(0, 4)
    : [];
const teaserFacts = totalCount === 0 ? sampleFacts(allFacts, 2) : [];
const subjectMeta = new Map(SUBJECTS.map((s) => [s.id, s] as const));
const issueUrl = `${SITE.repoUrl}/issues/new?title=${encodeURIComponent(`Факт під випуск ${year}`)}`;
const regionOptions = [
  { value: "world", label: "Світ" },
  { value: "ukraine", label: "Україна" },
] as const;
const impactOptions = [
  { value: "low", label: "Низький" },
  { value: "medium", label: "Середній" },
  { value: "high", label: "Високий" },
] as const;

// Усі year-сторінки регенеряться разом при кожному build — використовуємо
// build-time дату як `datePublished`/`dateModified`. Для трекінгу свіжості
// окремих фактів на сторінці буде поле `updatedAt` (PR #2.3).
const buildDate = new Date().toISOString();
const homeUrl = `${SITE.defaultUrl}/`;
const yearCanonical = new URL(Astro.url.pathname, SITE.defaultUrl).toString();
const articleHeadline =
  totalCount > 0
    ? `Випуск ${year}: ${totalCount} ${totalCount === 1 ? "оновлення" : "оновлень"} після випускного`
    : `Випуск ${year}: ${era.label}`;

const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleHeadline,
  description,
  image: ogImage,
  datePublished: buildDate,
  dateModified: buildDate,
  inLanguage: "uk",
  author: {
    "@type": "Organization",
    name: SITE.author,
    url: SITE.defaultUrl,
  },
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.defaultUrl,
  },
  mainEntityOfPage: yearCanonical,
};

const breadcrumbsLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Головна",
      item: homeUrl,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: `Випуск ${year}`,
      item: yearCanonical,
    },
  ],
};
---

<Base
  title={`Випуск ${year}`}
  description={description}
  ogImage={ogImage}
  jsonLd={[articleLd, breadcrumbsLd]}
>
  <section class="ruled-hero">
    <div class="container-prose pt-12 pb-12 sm:pt-16">
      <nav aria-label="Хлібні крихти" class="text-ink-500 dark:text-ink-400 text-sm">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li>
            <a
              href="/"
              class="hover:text-ink-900 dark:hover:text-ink-100 underline-offset-2 hover:underline"
              aria-label="На головну"
            >
              Головна
            </a>
          </li>
          <li aria-hidden="true" class="text-ink-300 dark:text-ink-600">›</li>
          <li>
            <span class="text-ink-700 dark:text-ink-200 font-medium" aria-current="page"
              >Випуск {year}</span
            >
          </li>
          <li aria-hidden="true" class="text-ink-300 dark:text-ink-600 ml-2">·</li>
          <li>
            <a
              href="/"
              class="hover:text-ink-900 dark:hover:text-ink-100 inline-flex items-center gap-1 underline-offset-2 hover:underline"
            >
              ← Інший рік
            </a>
          </li>
        </ol>
      </nav>

      <p
        class="text-accent-700 dark:text-accent-300 mt-4 flex flex-wrap items-center gap-2 text-sm font-medium tracking-widest"
      >
        <span
          class="bg-accent-50 text-accent-700 dark:bg-accent-900/40 dark:text-accent-200 rounded-full px-3 py-1 font-mono text-xs tabular-nums"
          >ВИПУСК {year}</span
        >
        <span class="text-ink-500 dark:text-ink-400 font-sans text-xs uppercase">·</span>
        <a
          href={eraUrl(era.slug)}
          class="text-ink-600 hover:text-accent-700 dark:text-ink-300 dark:hover:text-accent-300 text-xs uppercase underline-offset-2 hover:underline"
          >{era.label}</a
        >
      </p>
      <h1
        class="font-display text-ink-900 dark:text-ink-50 mt-3 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-5xl"
      >
        {
          totalCount > 0
            ? `Ти пропустив ${totalCount} ${totalCount === 1 ? "оновлення" : "оновлень"}`
            : "Тут поки тихо"
        }
      </h1>
      <p class="text-ink-700 dark:text-ink-200 mt-4 max-w-prose text-lg">{era.summary}</p>
    </div>
  </section>

  {
    groups.length > 0 && (
      <section class="container-prose mt-10" aria-labelledby="filters-heading">
        <div class="border-ink-100 bg-paper-50 dark:border-ink-700 dark:bg-ink-800 rounded-3xl border p-5 sm:p-6">
          <div class="flex flex-wrap items-end justify-between gap-3">
            <div>
              <h2
                id="filters-heading"
                class="font-display text-ink-900 dark:text-ink-50 text-lg font-bold tracking-tight"
              >
                Фільтри
              </h2>
              <p class="text-ink-500 dark:text-ink-400 mt-1 text-sm">
                Показано <span data-filter-result-count>{totalCount}</span> з {totalCount} фактів.
              </p>
            </div>
            <a
              href={`/${year}.html`}
              class="text-accent-700 hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200 text-sm font-medium underline-offset-2 hover:underline"
            >
              Скинути
            </a>
          </div>

          <form data-year-filters class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            <label class="block">
              <span class="text-ink-500 dark:text-ink-400 text-xs font-medium tracking-wider uppercase">
                Предмет
              </span>
              <select
                name="subject"
                class="border-ink-200 text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-100 mt-1 w-full rounded-xl border bg-white px-3 py-2 text-sm"
              >
                <option value="">Усі предмети</option>
                {SUBJECTS.map((s) => (
                  <option value={s.id}>{s.label}</option>
                ))}
              </select>
            </label>
            <label class="block">
              <span class="text-ink-500 dark:text-ink-400 text-xs font-medium tracking-wider uppercase">
                Ера
              </span>
              <select
                name="era"
                class="border-ink-200 text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-100 mt-1 w-full rounded-xl border bg-white px-3 py-2 text-sm"
              >
                <option value="">Усі ери</option>
                {ERAS.map((e) => (
                  <option value={String(e.id)}>{e.label}</option>
                ))}
              </select>
            </label>
            <label class="block">
              <span class="text-ink-500 dark:text-ink-400 text-xs font-medium tracking-wider uppercase">
                Регіон
              </span>
              <select
                name="region"
                class="border-ink-200 text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-100 mt-1 w-full rounded-xl border bg-white px-3 py-2 text-sm"
              >
                <option value="">Усі регіони</option>
                {regionOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
            <label class="block">
              <span class="text-ink-500 dark:text-ink-400 text-xs font-medium tracking-wider uppercase">
                Вплив
              </span>
              <select
                name="impact"
                class="border-ink-200 text-ink-900 dark:border-ink-700 dark:bg-ink-900 dark:text-ink-100 mt-1 w-full rounded-xl border bg-white px-3 py-2 text-sm"
              >
                <option value="">Усі рівні</option>
                {impactOptions.map((option) => (
                  <option value={option.value}>{option.label}</option>
                ))}
              </select>
            </label>
          </form>
          <p data-filter-empty class="text-ink-500 dark:text-ink-400 mt-4 hidden text-sm">
            За такими фільтрами фактів не знайдено.
          </p>
        </div>
      </section>
    )
  }

  {
    groups.length > 1 && (
      <nav
        class="border-ink-100 bg-paper-50/85 sticky top-0 z-30 border-b backdrop-blur"
        aria-label="Розділи цього року"
      >
        <div class="container-prose flex flex-nowrap items-center gap-1.5 overflow-x-auto py-2.5 sm:flex-wrap sm:overflow-visible">
          {groups.map((g) => (
            <a
              href={`#subject-${g.subject}`}
              data-subject-nav={g.subject}
              class="border-ink-200 text-ink-700 hover:border-accent-700 hover:text-accent-700 inline-flex shrink-0 items-center gap-1.5 rounded-full border bg-white px-3 py-1.5 text-sm font-medium whitespace-nowrap transition"
            >
              <span aria-hidden="true">{g.emoji}</span>
              <span>{g.label}</span>
              <span class="text-ink-500 font-mono text-xs tabular-nums" data-nav-count>
                {g.items.length}
              </span>
            </a>
          ))}
        </div>
      </nav>
    )
  }

  {
    groups.length > 0 ? (
      <section class="container-prose">
        {groups.map((g) => (
          <section id={`subject-${g.subject}`} data-subject-section class="mt-12 scroll-mt-20">
            <header class="mb-5 flex items-baseline gap-3">
              <span class="text-3xl" aria-hidden="true">
                {g.emoji}
              </span>
              <h2 class="font-display text-ink-900 dark:text-ink-50 text-2xl font-extrabold tracking-tight sm:text-3xl">
                {g.label}
              </h2>
              <span class="text-ink-500 dark:text-ink-400 ml-auto font-mono text-xs tabular-nums">
                <span data-filter-count>{g.items.length}</span>
                {g.items.length === 1 ? "оновлення" : "оновлень"}
              </span>
            </header>
            <div class="grid gap-4">
              {g.items.map((f) => (
                <div
                  data-fact-card
                  data-region={f.data.region ?? "world"}
                  data-era={f.data.relevantForEras.join(" ")}
                  data-subject={f.data.subject}
                  data-impact={f.data.impact ?? "medium"}
                >
                  <FactCard fact={f} />
                </div>
              ))}
            </div>
          </section>
        ))}
      </section>
    ) : (
      <section class="container-prose mt-12">
        <div class="border-ink-200 dark:border-ink-700 dark:bg-ink-800 rounded-3xl border border-dashed bg-white p-8">
          <p class="font-display text-ink-900 dark:text-ink-50 text-xl font-bold">
            Поки що для цього року тихо.
          </p>
          <p class="text-ink-600 dark:text-ink-300 mt-2 text-base">
            Ми постійно додаємо факти. Поки що — спробуй ери, де у нас точно є про що розказати:
          </p>

          {fallbackYears.length > 0 && (
            <ul class="mt-5 grid gap-2 sm:grid-cols-2">
              {fallbackYears.map((f) => (
                <li>
                  <a
                    href={`/${f.year}.html`}
                    class="border-ink-200 hover:border-accent-700 hover:bg-accent-50 dark:border-ink-700 dark:bg-ink-900 dark:hover:border-accent-400 dark:hover:bg-ink-800 group flex items-center justify-between gap-3 rounded-2xl border bg-white px-4 py-2.5 transition"
                  >
                    <span class="flex flex-col">
                      <span class="text-ink-900 dark:text-ink-50 font-mono text-base font-semibold tabular-nums">
                        {f.year}
                      </span>
                      <span class="text-ink-500 dark:text-ink-400 text-xs">{f.eraLabel}</span>
                    </span>
                    <span class="text-ink-500 group-hover:text-accent-700 dark:text-ink-400 dark:group-hover:text-accent-300 font-mono text-xs tabular-nums">
                      {f.count} {f.count === 1 ? "факт" : "фактів"}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}

          {teaserFacts.length > 0 && (
            <div class="mt-8">
              <p class="text-ink-500 dark:text-ink-400 mb-3 text-xs tracking-wider uppercase">
                Щоб ти не йшов з порожніми руками — ось що в нас уже є:
              </p>
              <div class="grid gap-4">
                {teaserFacts.map((f) => {
                  const meta = subjectMeta.get(f.data.subject);
                  return (
                    <div>
                      {meta && (
                        <p class="text-ink-500 dark:text-ink-400 mb-1.5 flex items-center gap-1.5 text-xs">
                          <span aria-hidden="true">{meta.emoji}</span>
                          <span>{meta.label}</span>
                        </p>
                      )}
                      <FactCard fact={f} />
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          <p class="text-ink-500 dark:text-ink-400 mt-6 text-sm">
            Хочеш, щоб ми додали факт під цей рік?{" "}
            <a
              href={issueUrl}
              class="text-accent-700 hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200 underline-offset-2 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Запропонуй у GitHub
            </a>
          </p>
        </div>
      </section>
    )
  }

  <script is:inline>
    (function () {
      const form = document.querySelector("[data-year-filters]");
      if (!(form instanceof HTMLFormElement)) return;

      const cards = Array.from(document.querySelectorAll("[data-fact-card]"));
      const sections = Array.from(document.querySelectorAll("[data-subject-section]"));
      const navItems = Array.from(document.querySelectorAll("[data-subject-nav]"));
      const countNode = document.querySelector("[data-filter-result-count]");
      const emptyNode = document.querySelector("[data-filter-empty]");
      const selects = Array.from(form.querySelectorAll("select"));
      const params = new URLSearchParams(window.location.search);

      selects.forEach(function (select) {
        const value = params.get(select.name) ?? "";
        if (value && select.querySelector('option[value="' + CSS.escape(value) + '"]')) {
          select.value = value;
        }
      });

      function selected(name) {
        const field = form.elements.namedItem(name);
        return field instanceof HTMLSelectElement ? field.value : "";
      }

      function visibleCardsIn(section) {
        return Array.from(section.querySelectorAll("[data-fact-card]")).filter(function (card) {
          return card instanceof HTMLElement && !card.hidden;
        }).length;
      }

      function updateUrl() {
        const url = new URL(window.location.href);
        selects.forEach(function (select) {
          if (select.value) {
            url.searchParams.set(select.name, select.value);
          } else {
            url.searchParams.delete(select.name);
          }
        });
        window.history.replaceState({}, "", url);
      }

      function update() {
        const subject = selected("subject");
        const era = selected("era");
        const region = selected("region");
        const impact = selected("impact");
        let visible = 0;

        cards.forEach(function (card) {
          if (!(card instanceof HTMLElement)) return;
          const cardEras = (card.dataset.era ?? "").split(" ");
          const matches =
            (!subject || card.dataset.subject === subject) &&
            (!era || cardEras.includes(era)) &&
            (!region || card.dataset.region === region) &&
            (!impact || card.dataset.impact === impact);
          card.hidden = !matches;
          if (matches) visible += 1;
        });

        sections.forEach(function (section) {
          if (!(section instanceof HTMLElement)) return;
          const sectionCount = visibleCardsIn(section);
          section.hidden = sectionCount === 0;
          const sectionCountNode = section.querySelector("[data-filter-count]");
          if (sectionCountNode) sectionCountNode.textContent = String(sectionCount);
        });

        navItems.forEach(function (item) {
          if (!(item instanceof HTMLElement)) return;
          const subjectId = item.dataset.subjectNav;
          const section = sections.find(function (candidate) {
            return candidate instanceof HTMLElement && candidate.id === "subject-" + subjectId;
          });
          const sectionCount = section instanceof HTMLElement ? visibleCardsIn(section) : 0;
          item.hidden = sectionCount === 0;
          const navCountNode = item.querySelector("[data-nav-count]");
          if (navCountNode) navCountNode.textContent = String(sectionCount);
        });

        if (countNode) countNode.textContent = String(visible);
        if (emptyNode instanceof HTMLElement) emptyNode.classList.toggle("hidden", visible > 0);
        updateUrl();
      }

      form.addEventListener("submit", function (event) {
        event.preventDefault();
      });
      selects.forEach(function (select) {
        select.addEventListener("change", update);
      });
      update();
    })();
  </script>

  <ShareBlock year={year} factsCount={totalCount} />

  <SupportBlock />

  <section class="container-prose mt-16">
    <h2 class="font-display text-ink-900 dark:text-ink-50 text-xl font-bold">Спробуй інший рік</h2>
    <div class="mt-4">
      <YearInput defaultYear={year} size="md" />
    </div>
  </section>
</Base>
