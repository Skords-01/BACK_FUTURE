---
import Base from "../layouts/Base.astro";
import YearHero from "../components/YearHero.astro";
import ThenAside from "../components/ThenAside.astro";
import SubjectFilters from "../components/SubjectFilters.astro";
import FactTimeline from "../components/FactTimeline.astro";
import YearNav from "../components/YearNav.astro";
import ShareBlock from "../components/ShareBlock.astro";
import SupportBlock from "../components/SupportBlock.astro";
import QuizCta from "../components/QuizCta.astro";
import ReadingProgress from "../components/ReadingProgress.astro";
import BackToTop from "../components/BackToTop.astro";
import { getCollection } from "astro:content";
import { factsForYear, pickFallbackYears, sampleFacts, type Fact } from "../lib/filterFacts";
import { eraOf } from "../lib/eras";
import { SITE, SUBJECTS } from "../config/site";

export async function getStaticPaths() {
  const years: { params: { year: string } }[] = [];
  for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
    years.push({ params: { year: String(y) } });
  }
  return years;
}

const { year: yearStr } = Astro.params;
const year = Number(yearStr);
if (!Number.isInteger(year) || year < SITE.yearMin || year > SITE.yearMax) {
  return Astro.redirect("/");
}

const allFacts = await getCollection("facts");
const matched = factsForYear(allFacts, year);
const era = eraOf(year);

const totalCount = matched.length;
const yearNow = new Date().getFullYear();
const yearsPassed = yearNow - year;

function pluralize(n: number, forms: [string, string, string]): string {
  const m10 = n % 10;
  const m100 = n % 100;
  if (m10 === 1 && m100 !== 11) return forms[0];
  if (m10 >= 2 && m10 <= 4 && (m100 < 12 || m100 > 14)) return forms[1];
  return forms[2];
}
const updatesLabel = pluralize(totalCount, ["оновлення", "оновлення", "оновлень"]);

const description = `Якщо ти випустився ${year}-го — ось що змінилось у науці й історії після того, як ти закрив підручник. ${SITE.name}.`;
const ogImage = new URL(`/og/${year}.png`, SITE.defaultUrl).toString();

const fallbackYears =
  totalCount === 0
    ? pickFallbackYears(year, allFacts)
        .filter((f) => f.year !== year)
        .slice(0, 4)
    : [];
const teaserFacts = totalCount === 0 ? sampleFacts(allFacts, 2) : [];
const subjectMeta = new Map(SUBJECTS.map((s) => [s.id, s] as const));
const issueUrl = `${SITE.repoUrl}/issues/new?title=${encodeURIComponent(`Факт під випуск ${year}`)}`;

const buildDate = new Date().toISOString();
const homeUrl = `${SITE.defaultUrl}/`;
const yearCanonical = new URL(Astro.url.pathname, SITE.defaultUrl).toString();
const articleHeadline =
  totalCount > 0
    ? `Випуск ${year}: ${totalCount} ${updatesLabel} після випускного`
    : `Випуск ${year}: ${era.label}`;

const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleHeadline,
  description,
  image: ogImage,
  datePublished: buildDate,
  dateModified: buildDate,
  inLanguage: "uk",
  author: { "@type": "Organization", name: SITE.author, url: SITE.defaultUrl },
  publisher: { "@type": "Organization", name: SITE.name, url: SITE.defaultUrl },
  mainEntityOfPage: yearCanonical,
};

const breadcrumbsLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Головна", item: homeUrl },
    { "@type": "ListItem", position: 2, name: `Випуск ${year}`, item: yearCanonical },
  ],
};

// Subject counts for the filter bar
const subjectCounts = SUBJECTS.map((s) => ({
  id: s.id,
  count: matched.filter((f) => f.data.subject === s.id).length,
}));
---

<Base
  title={`Випуск ${year}`}
  description={description}
  ogImage={ogImage}
  jsonLd={[articleLd, breadcrumbsLd]}
>
  <ReadingProgress />
  <BackToTop />
  <YearHero year={year} era={era} yearsPassed={yearsPassed} totalCount={totalCount} />

  <ThenAside year={year} />

  {
    totalCount > 0 ? (
      <>
        <SubjectFilters counts={subjectCounts} />
        <FactTimeline facts={matched} fromYear={year} />
      </>
    ) : (
      <section class="container-wide py-16">
        <div class="rounded-sm border border-dashed border-[color:var(--card-edge)] bg-[color:var(--card)] p-8 sm:p-12">
          <p class="font-display text-xl font-semibold text-[color:var(--ink)]">
            Поки що для цього року тихо.
          </p>
          <p class="mt-2 text-base text-[color:var(--ink-2)]">
            Ми постійно додаємо факти. Поки що — спробуй ери, де в нас точно є про що розказати:
          </p>

          {fallbackYears.length > 0 && (
            <ul class="mt-6 grid gap-2 sm:grid-cols-2">
              {fallbackYears.map((f) => (
                <li>
                  <a
                    href={`/${f.year}/`}
                    class="flex items-center justify-between gap-3 rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--paper)] px-4 py-3 transition hover:border-[color:var(--accent)]"
                  >
                    <span class="flex flex-col">
                      <span class="font-mono text-base font-semibold text-[color:var(--ink)] tabular-nums">
                        {f.year}
                      </span>
                      <span class="text-xs text-[color:var(--muted)]">{f.eraLabel}</span>
                    </span>
                    <span class="font-mono text-xs text-[color:var(--muted)] tabular-nums">
                      {f.count} {f.count === 1 ? "факт" : "фактів"}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}

          {teaserFacts.length > 0 && (
            <div class="mt-8">
              <p class="mb-3 font-mono text-xs tracking-widest text-[color:var(--muted)] uppercase">
                Щоб ти не йшов з порожніми руками — ось що є в нас:
              </p>
              <div class="grid gap-4">
                {teaserFacts.map((f: Fact) => {
                  const meta = subjectMeta.get(f.data.subject);
                  return (
                    <div>
                      {meta && (
                        <p class="mb-1.5 font-mono text-xs text-[color:var(--muted)]">
                          {meta.mark} · {meta.label}
                        </p>
                      )}
                      <div class="rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] p-4">
                        <p class="font-display text-base font-semibold text-[color:var(--ink)]">
                          {f.data.title}
                        </p>
                        <p class="mt-1 text-sm text-[color:var(--ink-2)]">{f.data.short}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}

          <p class="mt-6 text-sm text-[color:var(--ink-2)]">
            Хочеш, щоб ми додали факт під цей рік?{" "}
            <a
              href={issueUrl}
              class="text-[color:var(--accent)] underline-offset-2 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Запропонуй у GitHub
            </a>
          </p>
        </div>
      </section>
    )
  }

  {totalCount > 0 && <QuizCta factsCount={totalCount} />}
  <ShareBlock year={year} factsCount={totalCount} />
  <SupportBlock />
  <YearNav year={year} />
</Base>

<script>
  // Persist last visited year and track read facts via Intersection Observer.
  // State stored in localStorage under key "bf_user_state".
  const BF_KEY = "bf_user_state";

  function bfLoad() {
    try {
      const raw = localStorage.getItem(BF_KEY);
      const s = raw ? JSON.parse(raw) : {};
      return {
        lastYear: typeof s.lastYear === "number" ? s.lastYear : null,
        readFacts: Array.isArray(s.readFacts) ? s.readFacts : [],
        savedFacts: Array.isArray(s.savedFacts) ? s.savedFacts : [],
      };
    } catch {
      return { lastYear: null, readFacts: [] as string[], savedFacts: [] as string[] };
    }
  }

  function bfSave(s: { lastYear: number | null; readFacts: string[]; savedFacts: string[] }) {
    try {
      localStorage.setItem(BF_KEY, JSON.stringify(s));
    } catch {}
  }

  // Derive year from URL path (e.g. /2003/ → 2003)
  const yearMatch = location.pathname.match(/\/(\d{4})\/?$/);
  const pageYear = yearMatch ? parseInt(yearMatch[1], 10) : null;

  if (pageYear) {
    const s = bfLoad();
    s.lastYear = pageYear;
    bfSave(s);
  }

  const readObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const slug = (entry.target as HTMLElement).dataset.factSlug;
        if (!slug) return;
        const s = bfLoad();
        if (!s.readFacts.includes(slug)) {
          s.readFacts.push(slug);
          bfSave(s);
        }
        readObserver.unobserve(entry.target);
      });
    },
    { threshold: 0.5 },
  );

  document
    .querySelectorAll<HTMLElement>("[data-fact-slug]")
    .forEach((el) => readObserver.observe(el));
</script>

<script
  define:vars={{
    prevYear: year > SITE.yearMin ? year - 1 : null,
    nextYear: year < SITE.yearMax ? year + 1 : null,
  }}
>
  // Keyboard navigation: ← prev year, → next year
  document.addEventListener("keydown", function (e) {
    var tag = e.target && e.target.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT") return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    if (e.key === "ArrowLeft" && prevYear) {
      window.location.href = "/" + prevYear + "/";
    } else if (e.key === "ArrowRight" && nextYear) {
      window.location.href = "/" + nextYear + "/";
    }
  });
</script>
