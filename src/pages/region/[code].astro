---
import Base from "../../layouts/Base.astro";
import FactCard from "../../components/FactCard.astro";
import SupportBlock from "../../components/SupportBlock.astro";
import { getCollection } from "astro:content";
import { groupBySubject } from "../../lib/filterFacts";
import { COUNTRY_REGIONS, getFlag, getRegionLabel } from "../../lib/regions";
import { SITE } from "../../config/site";
import { pageUrl } from "../../lib/url";

// `/region/<iso2>/` index page — lists all facts with `region: country:<iso2>`.
// Static-paths is gated on COUNTRY_REGIONS to keep the build deterministic; any
// country not in the curated list won't generate a page even if a fact references
// it (validate-content already warns on that case).
export async function getStaticPaths() {
  const allFacts = await getCollection("facts");
  return COUNTRY_REGIONS.filter((c) =>
    allFacts.some((f) => f.data.region === `country:${c.code}`),
  ).map((c) => ({
    params: { code: c.code },
    props: { label: c.label, flag: getFlag(c.code) },
  }));
}

const { code } = Astro.params;
const { label, flag } = Astro.props;
const allFacts = await getCollection("facts");
const items = allFacts
  .filter((f) => !f.data.draft && f.data.region === `country:${code}`)
  .slice()
  .sort((a, b) => {
    if (b.data.yearOfEvent !== a.data.yearOfEvent) {
      return b.data.yearOfEvent - a.data.yearOfEvent;
    }
    return a.id.localeCompare(b.id);
  });
const groups = groupBySubject(items);
const totalCount = items.length;

const resolvedLabel = label ?? getRegionLabel(code) ?? code.toUpperCase();

const description = `Факти, пов'язані з країною ${resolvedLabel}: ${totalCount} ${
  totalCount === 1 ? "факт" : "фактів"
} на ${SITE.name}.`;
const ogImage = new URL("/og/default.png", SITE.defaultUrl).toString();
const homeUrl = `${SITE.defaultUrl}/`;
const canonical = new URL(Astro.url.pathname, SITE.defaultUrl).toString();

const collectionLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${resolvedLabel} — ${SITE.name}`,
  description,
  inLanguage: "uk",
  url: canonical,
  isPartOf: { "@type": "WebSite", name: SITE.name, url: SITE.defaultUrl },
};

const breadcrumbsLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Головна", item: homeUrl },
    { "@type": "ListItem", position: 2, name: `Регіон: ${resolvedLabel}`, item: canonical },
  ],
};

const otherRegions = COUNTRY_REGIONS.filter((c) => c.code !== code).filter((c) =>
  allFacts.some((f) => f.data.region === `country:${c.code}`),
);
---

<Base
  title={`Регіон: ${resolvedLabel}`}
  description={description}
  ogImage={ogImage}
  jsonLd={[collectionLd, breadcrumbsLd]}
>
  <section class="ruled-hero">
    <div class="container-prose pt-12 pb-12 sm:pt-16">
      <nav aria-label="Хлібні крихти" class="text-ink-500 dark:text-ink-400 text-sm">
        <ol class="flex flex-wrap items-center gap-1.5">
          <li>
            <a
              href="/"
              class="hover:text-ink-900 dark:hover:text-ink-900 underline-offset-2 hover:underline"
              aria-label="На головну"
            >
              Головна
            </a>
          </li>
          <li aria-hidden="true" class="text-ink-300 dark:text-ink-600">›</li>
          <li>
            <span class="text-ink-700 font-medium" aria-current="page">
              Регіон: {resolvedLabel}
            </span>
          </li>
        </ol>
      </nav>

      <p
        class="text-accent-700 dark:text-accent-300 mt-4 flex flex-wrap items-center gap-2 text-sm font-medium tracking-widest"
      >
        <span
          class="bg-accent-50 text-accent-700 dark:bg-accent-900/40 dark:text-accent-200 rounded-full px-3 py-1 font-mono text-xs uppercase tabular-nums"
          >Регіон · {code.toUpperCase()}</span
        >
      </p>
      <h1
        class="font-display text-ink-900 mt-3 flex items-center gap-3 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-5xl"
      >
        <span aria-hidden="true">{flag ?? getFlag(code)}</span>
        <span>{resolvedLabel}</span>
      </h1>
      <p class="text-ink-500 dark:text-ink-400 mt-3 text-sm">
        {totalCount}
        {totalCount === 1 ? "факт" : "фактів"}, згруповано за предметами.
      </p>
    </div>
  </section>

  {
    groups.length > 0 ? (
      <section class="container-prose">
        {groups.map((g) => (
          <section id={`subject-${g.subject}`} class="mt-12 scroll-mt-20">
            <header class="mb-5 flex items-center gap-3">
              <h2 class="font-display text-ink-900 text-2xl font-extrabold tracking-tight sm:text-3xl">
                {g.label}
              </h2>
              <span class="text-ink-500 dark:text-ink-400 ml-auto font-mono text-xs tabular-nums">
                {g.items.length}
                {g.items.length === 1 ? " оновлення" : " оновлень"}
              </span>
            </header>
            <div class="grid gap-4">
              {g.items.map((f) => (
                <div data-reveal>
                  <FactCard fact={f} />
                </div>
              ))}
            </div>
          </section>
        ))}
      </section>
    ) : (
      <section class="container-prose mt-12">
        <div class="border-ink-200 rounded-3xl border border-dashed bg-white p-8 dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)]">
          <p class="font-display text-ink-900 text-xl font-bold">
            Для цього регіону поки немає фактів.
          </p>
        </div>
      </section>
    )
  }

  <SupportBlock />

  {
    otherRegions.length > 0 && (
      <section class="container-prose mt-16">
        <h2 class="font-display text-ink-900 text-xl font-bold">Інші країни</h2>
        <div class="mt-4 grid gap-2 sm:grid-cols-2">
          {otherRegions.map((c) => (
            <a
              href={pageUrl(`region/${c.code}`)}
              class="border-ink-200 hover:border-accent-700 hover:bg-accent-50 dark:hover:border-accent-400 group flex items-center justify-between gap-3 rounded-2xl border bg-white px-4 py-3 transition dark:border-[color:var(--card-edge)] dark:bg-[color:var(--card)] dark:hover:bg-[color:var(--paper-3)]"
            >
              <span class="flex items-center gap-3">
                <span aria-hidden="true" class="text-lg">
                  {getFlag(c.code)}
                </span>
                <span class="text-ink-800 dark:text-ink-900 font-medium">{c.label}</span>
              </span>
              <span class="text-ink-400 group-hover:text-accent-700 dark:group-hover:text-accent-300">
                →
              </span>
            </a>
          ))}
        </div>
      </section>
    )
  }
</Base>
