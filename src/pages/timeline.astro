---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";
import { SUBJECTS, type SubjectId } from "../config/site";
import { ERAS } from "../lib/eras";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);

const facts = allFacts
  .map((fact) => ({
    id: fact.id,
    title: fact.data.title,
    short: fact.data.short,
    year: fact.data.yearOfEvent,
    subject: fact.data.subject as SubjectId,
    relevantForEras: fact.data.relevantForEras,
  }))
  .sort((a, b) => b.year - a.year);

const subjectsById = new Map(SUBJECTS.map((s) => [s.id, s]));

const decades: { decade: number; items: typeof facts }[] = [];
for (const fact of facts) {
  const decade = Math.floor(fact.year / 10) * 10;
  let bucket = decades.find((d) => d.decade === decade);
  if (!bucket) {
    bucket = { decade, items: [] };
    decades.push(bucket);
  }
  bucket.items.push(fact);
}

const description = `Хронологія важливих подій у науці й історії з 1990-х до сьогодні — ${facts.length} фактів від ${SUBJECTS.length} предметів. ${facts.length > 0 ? "Збираємо постійно." : ""}`;
---

<Base title="Хронологія" description={description}>
  <section class="container-prose pt-16">
    <p class="text-accent-700 mb-3 text-sm font-medium tracking-widest uppercase">
      Усе на одній лінії часу
    </p>
    <h1 class="font-display text-ink-900 text-4xl font-extrabold tracking-tight sm:text-5xl">
      Хронологія
    </h1>
    <p class="text-ink-700 mt-4 max-w-prose text-lg">
      {facts.length} оновлень у науці й історії, які лягли на сторінки шкільних підручників лише після
      того, як ти випустився. Найновіші — згори.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-2">
      <span class="text-ink-500 mr-2 text-xs font-medium tracking-wider uppercase">Фільтр:</span>
      <button type="button" class="timeline-pill" data-filter="all" data-active="true">
        Усі
      </button>
      {
        SUBJECTS.map((s) => (
          <button type="button" class="timeline-pill" data-filter={s.id}>
            <span aria-hidden="true">{s.emoji}</span>
            <span>{s.label}</span>
          </button>
        ))
      }
    </div>

    <p class="text-ink-500 mt-3 text-xs">
      Кліпай на роки, щоб перейти на персональну сторінку випуску.
    </p>
  </section>

  <section class="container-prose mt-10">
    <ol class="border-ink-200 relative space-y-12 border-l pl-6 sm:pl-8">
      {
        decades.map((bucket) => (
          <li class="timeline-decade">
            <div class="bg-ink-50 border-ink-200 sticky top-2 z-10 mb-4 -ml-9 inline-block rounded-full border bg-white px-4 py-1 font-mono text-sm font-bold tracking-tight tabular-nums sm:-ml-11">
              {bucket.decade}-ті
            </div>
            <ul class="space-y-6">
              {bucket.items.map((f) => {
                const subjectInfo = subjectsById.get(f.subject);
                return (
                  <li class="timeline-fact" data-subject={f.subject}>
                    <span
                      class="bg-accent-700 absolute mt-2 -ml-[1.625rem] inline-block h-2.5 w-2.5 rounded-full sm:-ml-[2.125rem]"
                      aria-hidden="true"
                    />
                    <article class="border-ink-100 shadow-card rounded-2xl border bg-white p-4 sm:p-5">
                      <div class="flex items-start justify-between gap-3">
                        <a
                          class="hover:text-accent-800 bg-accent-50 text-accent-700 inline-flex items-center rounded-full px-3 py-1 font-mono text-xs font-medium tabular-nums"
                          href={`/${f.year}.html`}
                          aria-label={`Перейти до випуску ${f.year}`}
                        >
                          {f.year}
                        </a>
                        <span class="text-ink-500 ml-auto text-xs">
                          <span aria-hidden="true">{subjectInfo?.emoji ?? ""}</span>{" "}
                          {subjectInfo?.label ?? f.subject}
                        </span>
                      </div>
                      <h3 class="font-display text-ink-900 mt-2 text-lg leading-snug font-bold">
                        {f.title}
                      </h3>
                      <p class="text-ink-700 mt-2 text-sm leading-relaxed">{f.short}</p>
                    </article>
                  </li>
                );
              })}
            </ul>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="container-prose mt-16">
    <h2 class="font-display text-ink-900 text-xl font-bold">Що означають десятиліття</h2>
    <p class="text-ink-700 mt-2 max-w-prose">
      Хронологія використовує рік події. Натомість для персонального випуску ми пов'язуємо рік
      випуску з ерою шкільної програми. Дивись{" "}
      <a class="hover:text-ink-900 underline" href="/metodologia.html">методологію</a>.
    </p>
    <details class="text-ink-700 group mt-4 text-sm">
      <summary class="text-accent-700 cursor-pointer font-medium"
        >Список ер шкільних програм</summary
      >
      <ul class="mt-3 space-y-2">
        {
          ERAS.map((e) => (
            <li class="border-ink-100 rounded-2xl border bg-white p-3">
              <div class="font-display text-ink-900 font-bold">{e.label}</div>
              <div class="text-ink-600 mt-1 text-xs">{e.summary}</div>
            </li>
          ))
        }
      </ul>
    </details>
  </section>
</Base>

<style is:global>
  .timeline-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    border: 1px solid #d6d6d2;
    background: #fff;
    color: #4d4d47;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition:
      border-color 150ms ease,
      color 150ms ease,
      background 150ms ease;
  }
  .timeline-pill:hover {
    border-color: #8a8a82;
    color: #16161a;
  }
  .timeline-pill[data-active="true"] {
    background: #1e3a8a;
    border-color: #1e3a8a;
    color: #fff;
  }
  .timeline-fact {
    position: relative;
    transition: opacity 150ms ease;
  }
  .timeline-fact[data-hidden="true"] {
    display: none;
  }
  .timeline-decade[data-empty="true"] {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    const buttons = Array.from(document.querySelectorAll(".timeline-pill"));
    const facts = Array.from(document.querySelectorAll(".timeline-fact"));
    const decades = Array.from(document.querySelectorAll(".timeline-decade"));
    if (buttons.length === 0) return;

    let currentFilter = "all";

    function applyFilter(value) {
      currentFilter = value;
      buttons.forEach(function (btn) {
        if (btn instanceof HTMLElement) {
          if (btn.dataset.filter === value) {
            btn.dataset.active = "true";
          } else {
            btn.removeAttribute("data-active");
          }
        }
      });
      facts.forEach(function (el) {
        if (el instanceof HTMLElement) {
          const match = value === "all" || el.dataset.subject === value;
          if (match) {
            el.removeAttribute("data-hidden");
          } else {
            el.dataset.hidden = "true";
          }
        }
      });
      decades.forEach(function (el) {
        if (el instanceof HTMLElement) {
          const visibleFacts = el.querySelectorAll('.timeline-fact:not([data-hidden="true"])');
          if (visibleFacts.length === 0) {
            el.dataset.empty = "true";
          } else {
            el.removeAttribute("data-empty");
          }
        }
      });
    }

    buttons.forEach(function (btn) {
      if (!(btn instanceof HTMLElement)) return;
      btn.addEventListener("click", function () {
        applyFilter(btn.dataset.filter || "all");
      });
    });

    void currentFilter;
  })();
</script>
