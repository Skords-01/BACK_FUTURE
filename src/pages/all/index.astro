---
import Base from "../../layouts/Base.astro";
import FactCard from "../../components/FactCard.astro";
import { getCollection } from "astro:content";
import { SUBJECTS, SITE } from "../../config/site";
import { ERAS } from "../../lib/eras";
import type { EraId } from "../../lib/eras";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);

// Parse URL query params for filtering
const url = new URL(Astro.request.url);
const qSubject = url.searchParams.get("subject") ?? "";
const qEra = url.searchParams.get("era") ?? "";

let filtered = allFacts.slice().sort((a, b) => {
  if (b.data.yearOfEvent !== a.data.yearOfEvent) {
    return b.data.yearOfEvent - a.data.yearOfEvent;
  }
  return a.id.localeCompare(b.id);
});

if (qSubject) {
  filtered = filtered.filter((f) => f.data.subject === qSubject);
}
if (qEra) {
  const eraId = Number(qEra) as EraId;
  filtered = filtered.filter((f) => f.data.relevantForEras.includes(eraId));
}

const totalFacts = allFacts.length;
const filteredCount = filtered.length;

const description = `Усі ${totalFacts} фактів про науку, історію і світ від ${SITE.yearMin} року. Фільтруй за предметом або епохою.`;
---

<Base title={`Усі факти · ${totalFacts}`} description={description}>
  <div class="container-wide py-12">
    <!-- Page header -->
    <div class="mb-10 border-b border-[color:var(--rule)] pb-8">
      <nav class="mb-4 font-mono text-xs text-[color:var(--muted)]">
        <a href="/" class="underline-offset-2 hover:text-[color:var(--accent)] hover:underline">
          ← Головна
        </a>
      </nav>
      <h1
        class="font-display text-[clamp(2.5rem,6vw,5rem)] leading-none font-extrabold tracking-[-0.04em] text-[color:var(--ink)]"
      >
        Усі факти
      </h1>
      <p class="mt-3 text-lg text-[color:var(--ink-2)]">
        {totalFacts} оновлень від {SITE.yearMin} року — наука, історія, технології.
      </p>
    </div>

    <!-- Filters -->
    <form method="get" action="/all/" class="mb-8 flex flex-wrap gap-3">
      <label class="flex flex-col gap-1">
        <span class="font-mono text-[10px] tracking-widest text-[color:var(--muted)] uppercase">
          Предмет
        </span>
        <select
          name="subject"
          class="min-h-10 rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] px-3 py-2 font-mono text-sm text-[color:var(--ink)]"
        >
          <option value="" selected={!qSubject}>Усі предмети</option>
          {
            SUBJECTS.map((s) => (
              <option value={s.id} selected={qSubject === s.id}>
                {s.mark} · {s.label}
              </option>
            ))
          }
        </select>
      </label>
      <label class="flex flex-col gap-1">
        <span class="font-mono text-[10px] tracking-widest text-[color:var(--muted)] uppercase">
          Епоха
        </span>
        <select
          name="era"
          class="min-h-10 rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] px-3 py-2 font-mono text-sm text-[color:var(--ink)]"
        >
          <option value="" selected={!qEra}>Усі епохи</option>
          {
            ERAS.map((e) => (
              <option value={String(e.id)} selected={qEra === String(e.id)}>
                {e.name} ({e.short})
              </option>
            ))
          }
        </select>
      </label>
      <div class="flex items-end gap-2">
        <button
          type="submit"
          class="min-h-10 rounded-sm bg-[color:var(--accent)] px-5 py-2 font-mono text-sm font-semibold text-white transition hover:opacity-90"
        >
          Фільтрувати
        </button>
        {
          (qSubject || qEra) && (
            <a
              href="/all/"
              class="flex min-h-10 items-center rounded-sm border border-[color:var(--card-edge)] px-4 py-2 font-mono text-sm text-[color:var(--muted)] transition hover:text-[color:var(--ink)]"
            >
              Скинути
            </a>
          )
        }
      </div>
    </form>

    <!-- Result count -->
    <p class="mb-6 font-mono text-xs text-[color:var(--muted)]">
      {qSubject || qEra ? `Показано ${filteredCount} з ${totalFacts}` : `${totalFacts} фактів`}
    </p>

    <!-- Facts grid -->
    {
      filtered.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {filtered.map((f) => (
            <FactCard fact={f} />
          ))}
        </div>
      ) : (
        <div class="rounded-sm border border-dashed border-[color:var(--card-edge)] p-12 text-center">
          <p class="font-display text-xl font-semibold text-[color:var(--ink)]">
            Нічого не знайдено.
          </p>
          <p class="mt-2 text-[color:var(--ink-2)]">Спробуй інші фільтри.</p>
          <a
            href="/all/"
            class="mt-4 inline-block font-mono text-sm text-[color:var(--accent)] hover:underline"
          >
            Скинути →
          </a>
        </div>
      )
    }
  </div>
</Base>
