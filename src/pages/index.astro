---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Presets from "../components/Presets.astro";
import { SITE, SUBJECTS } from "../config/site";
import { getCollection } from "astro:content";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const totalFacts = allFacts.length;

const DEFAULT_YEAR = 2012;

// Precompute facts count from each graduation year (year → count of facts since that year).
const factsFromYear: Record<number, number> = {};
for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
  factsFromYear[y] = allFacts.filter((f) => f.data.yearOfEvent >= y).length;
}

const websiteLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  alternateName: SITE.tagline,
  url: SITE.defaultUrl,
  description: SITE.description,
  inLanguage: "uk",
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.defaultUrl,
  },
};
---

<Base jsonLd={websiteLd}>
  <div class="container-wide">
    <Hero totalFacts={totalFacts} factsFromYear={factsFromYear} defaultYear={DEFAULT_YEAR} />

    <!-- Ери, DensityStrip, SubjectChips will be added in Epic 3 -->

    <!-- Як це працює -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-6">
      <div class="flex items-baseline justify-between gap-6 mb-8">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-none tracking-tight text-[color:var(--ink)]"
        >
          Як це працює
        </h2>
        <span class="hidden font-mono text-xs tracking-widest uppercase text-[color:var(--muted)] sm:inline">
          3 кроки
        </span>
      </div>
      <ol class="grid gap-6 sm:grid-cols-3">
        {
          [
            {
              n: "01",
              title: "Введи рік випуску.",
              text: "Від 1991 до сьогодні.",
            },
            {
              n: "02",
              title: "Отримаєш стрічку.",
              text: "11 предметів · хронологічно · з епіграфом епохи.",
            },
            {
              n: "03",
              title: "Кожен факт — з джерелом.",
              text: "Розгорни деталі або поділись як вирізкою.",
            },
          ].map((step) => (
            <li class="rounded-sm border border-[color:var(--card-edge)] border-l-4 border-l-[color:var(--accent)] bg-[color:var(--card)] p-6 text-base leading-relaxed text-[color:var(--ink-2)]">
              <span class="font-mono text-xs font-bold tracking-[0.15em] text-[color:var(--accent)]">
                {step.n}
              </span>
              <strong class="mt-3 mb-2 block font-display text-xl font-semibold tracking-tight text-[color:var(--ink)]">
                {step.title}
              </strong>
              {step.text}
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Або одразу — preset cards -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-6">
      <div class="flex items-baseline justify-between gap-6 mb-8">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-none tracking-tight text-[color:var(--ink)]"
        >
          Або одразу
        </h2>
      </div>
      <Presets />
      <p class="mt-6 text-center">
        <a
          href="/all/"
          class="font-mono text-sm text-[color:var(--muted)] underline-offset-4 hover:text-[color:var(--accent)] hover:underline"
        >
          Усі {totalFacts} фактів →
        </a>
      </p>
    </section>

    <!-- Тематичні рубрики -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-24">
      <div class="flex items-baseline justify-between gap-6 mb-8">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] font-semibold leading-none tracking-tight text-[color:var(--ink)]"
        >
          Тематичні рубрики
        </h2>
        <span class="hidden font-mono text-xs tracking-widest uppercase text-[color:var(--muted)] sm:inline">
          11 предметів
        </span>
      </div>
      <ul class="flex flex-wrap gap-2.5">
        {
          SUBJECTS.map((s) => (
            <li>
              <a
                href={`/subject/${s.id}/`}
                class="chip"
                style={`--chip-color: var(--subject-${s.id})`}
              >
                <span class="chip__code">{s.mark}</span>
                <span class="chip__name">{s.label}</span>
                <span class="chip__count">
                  {allFacts.filter((f) => f.data.subject === s.id).length}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>
