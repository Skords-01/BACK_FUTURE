---
import Base from "../layouts/Base.astro";
import YearInput from "../components/YearInput.astro";
import { SITE, SUBJECTS } from "../config/site";
import { getCollection } from "astro:content";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const totalFacts = allFacts.length;

// Pick 3 teasers — one from each of distinct subjects when possible.
const seenSubjects = new Set<string>();
const teasers = allFacts
  .slice()
  .sort((a, b) => b.data.yearOfEvent - a.data.yearOfEvent)
  .filter((f) => {
    if (seenSubjects.has(f.data.subject)) return false;
    seenSubjects.add(f.data.subject);
    return true;
  })
  .slice(0, 3)
  .map((f) => {
    const subject = SUBJECTS.find((s) => s.id === f.data.subject);
    return {
      id: f.id,
      year: f.data.yearOfEvent,
      title: f.data.title,
      short: f.data.short,
      subjectLabel: subject?.label ?? f.data.subject,
      subjectEmoji: subject?.emoji ?? "📌",
    };
  });
---

<Base>
  <section class="ruled-hero">
    <div class="container-prose pt-16 sm:pt-24">
      <p class="text-accent-700 mb-3 text-sm font-medium tracking-widest uppercase">
        Українською. Без підписки.
      </p>
      <h1
        class="font-display text-ink-900 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-6xl"
      >
        Що ти пропустив після випускного?
      </h1>
      <p class="text-ink-700 mt-5 max-w-prose text-lg leading-relaxed sm:text-xl">
        Введи рік випуску й дізнайся, що змінилось у науці, історії й світі від тих часів. Стисло,
        науково-популярно, з джерелами.
      </p>

      <div class="mt-10 pb-16">
        <YearInput defaultYear={2003} />
        <p class="text-ink-500 mt-3 text-sm">
          Підтримуються роки {SITE.yearMin}–{SITE.yearMax}.
        </p>
      </div>
    </div>
  </section>

  <section class="container-prose mt-20">
    <h2 class="font-display text-ink-900 text-xl font-bold">Як це працює</h2>
    <ol class="text-ink-700 mt-4 space-y-3">
      <li>
        <span class="text-ink-900 font-semibold">1. Введи рік випуску.</span> Від 1991 до сьогодні.
      </li>
      <li>
        <span class="text-ink-900 font-semibold">2. Отримаєш стрічку оновлень</span> по 5 предметах: астрономія,
        біологія, географія, історія, фізика. Те, що змінилось у науці й світі від твого випускного року.
      </li>
      <li>
        <span class="text-ink-900 font-semibold">3. Кожен факт — з джерелом.</span> Можна розгорнути деталі
        в науково-популярному форматі.
      </li>
    </ol>
  </section>

  <section class="container-prose mt-16">
    <h2 class="font-display text-ink-900 text-xl font-bold">Тематичні блоки</h2>
    <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-5">
      {
        SUBJECTS.map((s) => (
          <li class="border-ink-100 flex flex-col items-start rounded-2xl border bg-white p-4">
            <span class="text-2xl">{s.emoji}</span>
            <span class="text-ink-900 mt-2 font-medium">{s.label}</span>
          </li>
        ))
      }
    </ul>
    <p class="text-ink-500 mt-4 text-sm">
      Зараз у базі: <span class="text-ink-700 font-semibold">{totalFacts}</span>{" "}
      {totalFacts === 1 ? "факт" : "фактів"}. Поповнюємо постійно.
    </p>
  </section>

  {
    teasers.length > 0 && (
      <section class="container-prose mt-16">
        <div class="flex items-end justify-between gap-4">
          <h2 class="font-display text-ink-900 text-xl font-bold">Свіжі факти з бази</h2>
          <a
            class="text-accent-700 hover:text-accent-900 text-sm font-medium"
            href="/timeline.html"
          >
            Уся хронологія →
          </a>
        </div>
        <ul class="mt-5 grid gap-4 sm:grid-cols-3">
          {teasers.map((t, i) => (
            <li
              class="teaser-card border-ink-100 shadow-card hover:shadow-card-hover rounded-3xl border bg-white p-5"
              style={`--teaser-delay: ${i * 90}ms`}
            >
              <div class="flex items-start justify-between gap-3">
                <a
                  class="hover:text-accent-800 bg-accent-50 text-accent-700 inline-flex items-center rounded-full px-3 py-1 font-mono text-xs font-medium tabular-nums"
                  href={`/${t.year}.html`}
                >
                  {t.year}
                </a>
                <span class="text-ink-400 text-xs">
                  <span aria-hidden="true">{t.subjectEmoji}</span> {t.subjectLabel}
                </span>
              </div>
              <h3 class="font-display text-ink-900 mt-3 text-lg leading-snug font-bold">
                {t.title}
              </h3>
              <p class="text-ink-700 mt-2 line-clamp-3 text-sm leading-relaxed">{t.short}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="container-prose mt-20 mb-12">
    <div
      class="border-ink-100 shadow-card relative overflow-hidden rounded-3xl border bg-white p-6 sm:p-8"
    >
      <div class="grid gap-6 sm:grid-cols-3">
        <a href="/timeline.html" class="ghost-card group">
          <span class="text-3xl" aria-hidden="true">🧭</span>
          <h3 class="font-display text-ink-900 mt-3 text-lg font-bold">Хронологія</h3>
          <p class="text-ink-600 mt-1 text-sm">Усе на одній стрічці часу — фільтр по предметах.</p>
        </a>
        <a href="/kviz.html" class="ghost-card group">
          <span class="text-3xl" aria-hidden="true">🎯</span>
          <h3 class="font-display text-ink-900 mt-3 text-lg font-bold">Квіз</h3>
          <p class="text-ink-600 mt-1 text-sm">Вгадай рік відкриття. 5 запитань на основі бази.</p>
        </a>
        <a href="/temy.html" class="ghost-card group">
          <span class="text-3xl" aria-hidden="true">📚</span>
          <h3 class="font-display text-ink-900 mt-3 text-lg font-bold">Теми</h3>
          <p class="text-ink-600 mt-1 text-sm">
            Зв'язок зі шкільною програмою — що оновилось у яких главах.
          </p>
        </a>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    .teaser-card {
      opacity: 0;
      transform: translateY(8px);
      animation: teaser-in 480ms ease-out forwards;
      animation-delay: var(--teaser-delay, 0ms);
    }
    @keyframes teaser-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  }
  .ghost-card {
    display: block;
    border: 1px solid #e6e6e2;
    background: #fafaf8;
    border-radius: 1.5rem;
    padding: 1rem 1.25rem;
    text-decoration: none;
    transition:
      border-color 150ms ease,
      transform 150ms ease,
      background 150ms ease;
  }
  .ghost-card:hover {
    border-color: #1e3a8a;
    background: #fff;
    transform: translateY(-2px);
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
