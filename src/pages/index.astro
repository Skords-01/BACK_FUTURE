---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import EraGrid from "../components/EraGrid.astro";
import DensityStrip from "../components/DensityStrip.astro";
import SubjectChips from "../components/SubjectChips.astro";
import Presets from "../components/Presets.astro";
import InstallPwaButton from "../components/InstallPwaButton.astro";
import { SITE } from "../config/site";
import { getCollection } from "astro:content";
import { factsWord } from "../lib/plurals";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const totalFacts = allFacts.length;

const DEFAULT_YEAR = 2012;

// Precompute facts count from each graduation year (year → count of facts since that year).
const factsFromYear: Record<number, number> = {};
for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
  factsFromYear[y] = allFacts.filter((f) => f.data.yearOfEvent >= y).length;
}

// Featured fact title per year — highest-impact fact (impact=high preferred), else first by id.
const featuredByYear: Record<number, string> = {};
for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
  const yearFacts = allFacts.filter((f) => f.data.yearOfEvent === y);
  if (yearFacts.length === 0) continue;
  const top = yearFacts.find((f) => f.data.impact === "high") ?? yearFacts[0]!;
  featuredByYear[y] = top.data.title;
}

const websiteLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  alternateName: SITE.tagline,
  url: SITE.defaultUrl,
  description: SITE.description,
  inLanguage: "uk",
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.defaultUrl,
  },
};
---

<Base jsonLd={websiteLd}>
  <div class="container-wide">
    <Hero totalFacts={totalFacts} factsFromYear={factsFromYear} defaultYear={DEFAULT_YEAR} />

    <!-- П'ять епох -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-6">
      <div class="mb-8 flex items-baseline justify-between gap-6">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-none font-semibold tracking-tight text-[color:var(--ink)]"
          data-reveal
        >
          П'ять епох
        </h2>
        <span
          class="hidden font-mono text-xs tracking-widest text-[color:var(--muted)] uppercase sm:inline"
        >
          навчальні покоління, 1991—сьогодні
        </span>
      </div>
      <EraGrid />
    </section>

    <!-- Густина часу -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-10">
      <div class="mb-8 flex items-baseline justify-between gap-6">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-none font-semibold tracking-tight text-[color:var(--ink)]"
          data-reveal
        >
          Густина часу
        </h2>
        <span
          class="hidden font-mono text-xs tracking-widest text-[color:var(--muted)] uppercase sm:inline"
        >
          висота смужки = кількість фактів того року
        </span>
      </div>
      <DensityStrip featuredByYear={featuredByYear} />
    </section>

    <!-- Як це працює -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-6">
      <div class="mb-8 flex items-baseline justify-between gap-6">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-none font-semibold tracking-tight text-[color:var(--ink)]"
          data-reveal
        >
          Як це працює
        </h2>
        <span
          class="hidden font-mono text-xs tracking-widest text-[color:var(--muted)] uppercase sm:inline"
        >
          3 кроки
        </span>
      </div>
      <ol class="grid gap-6 sm:grid-cols-3">
        {
          [
            {
              n: "01",
              title: "Введи рік випуску.",
              text: "Від 1991 до сьогодні.",
            },
            {
              n: "02",
              title: "Отримаєш стрічку.",
              text: "11 предметів · хронологічно · з епіграфом епохи.",
            },
            {
              n: "03",
              title: "Кожен факт — з джерелом.",
              text: "Розгорни деталі або поділись фактом.",
            },
          ].map((step, i) => (
            <li
              class="rounded-sm border border-l-4 border-[color:var(--card-edge)] border-l-[color:var(--accent)] bg-[color:var(--card)] p-6 text-base leading-relaxed text-[color:var(--ink-2)]"
              data-reveal
              style={`--reveal-delay: ${i * 80}ms`}
            >
              <span class="font-mono text-xs font-bold tracking-[0.15em] text-[color:var(--accent)]">
                {step.n}
              </span>
              <strong class="font-display mt-3 mb-2 block text-xl font-semibold tracking-tight text-[color:var(--ink)]">
                {step.title}
              </strong>
              {step.text}
            </li>
          ))
        }
      </ol>
    </section>

    <!-- Або одразу — preset cards -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-6">
      <div class="mb-8 flex items-baseline justify-between gap-6">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-none font-semibold tracking-tight text-[color:var(--ink)]"
          data-reveal
        >
          Або відразу до
        </h2>
      </div>
      <Presets />
      <p class="mt-6 text-center">
        <a
          href="/all/"
          class="font-mono text-sm text-[color:var(--muted)] underline-offset-4 hover:text-[color:var(--accent)] hover:underline"
        >
          Усі {totalFacts}
          {factsWord(totalFacts)} →
        </a>
      </p>
    </section>

    <!-- Тематичні рубрики -->
    <section class="border-t border-[color:var(--rule)] pt-20 pb-24">
      <div class="mb-8 flex items-baseline justify-between gap-6">
        <h2
          class="font-display text-[clamp(2rem,4.5vw,3.5rem)] leading-none font-semibold tracking-tight text-[color:var(--ink)]"
          data-reveal
        >
          Тематичні рубрики
        </h2>
        <span
          class="hidden font-mono text-xs tracking-widest text-[color:var(--muted)] uppercase sm:inline"
        >
          11 предметів
        </span>
      </div>
      <SubjectChips />
    </section>
  </div>
  <InstallPwaButton />
</Base>
