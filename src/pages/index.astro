---
import Base from "../layouts/Base.astro";
import YearInput from "../components/YearInput.astro";
import Timeline from "../components/Timeline.astro";
import { SITE, SUBJECTS } from "../config/site";
import { getCollection } from "astro:content";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const totalFacts = allFacts.length;

// Quick-jump chips: середини декад + поточний рік. Допомагає тим, хто
// не хоче друкувати на мобілці й сумнівається в точному році.
const quickYears: number[] = [];
for (let y = 1995; y <= SITE.yearMax; y += 5) {
  quickYears.push(y);
}
if (!quickYears.includes(SITE.yearMax)) {
  quickYears.push(SITE.yearMax);
}

const websiteLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  alternateName: SITE.tagline,
  url: SITE.defaultUrl,
  description: SITE.description,
  inLanguage: "uk",
  publisher: {
    "@type": "Organization",
    name: SITE.name,
    url: SITE.defaultUrl,
  },
};
---

<Base jsonLd={websiteLd}>
  <section class="ruled-hero">
    <div class="container-prose pt-16 sm:pt-24">
      <p
        class="text-accent-700 dark:text-accent-300 mb-3 text-sm font-medium tracking-widest uppercase"
      >
        Українською. Без підписки.
      </p>
      <h1
        class="font-display text-ink-900 dark:text-ink-50 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-6xl"
      >
        Що ти пропустив після випускного?
      </h1>
      <p class="text-ink-700 dark:text-ink-200 mt-5 max-w-prose text-lg leading-relaxed sm:text-xl">
        Введи рік випуску й дізнайся, що змінилось у науці, історії й світі від тих часів. Стисло,
        науково-популярно, з джерелами.
      </p>

      <div class="mt-10 pb-4">
        <YearInput defaultYear={2003} />
        <p class="text-ink-500 dark:text-ink-400 mt-3 text-sm">
          Підтримуються роки {SITE.yearMin}–{SITE.yearMax}.
        </p>
      </div>

      <Timeline facts={allFacts} />

      <div class="pb-16">
        <p class="text-ink-500 dark:text-ink-400 mb-2 text-xs tracking-wider uppercase">
          Швидкий вибір
        </p>
        <ul class="-mx-1 flex flex-wrap items-center gap-1.5">
          {
            quickYears.map((y) => (
              <li>
                <a
                  href={`/${y}/`}
                  class="border-ink-200 text-ink-700 hover:border-accent-700 hover:text-accent-700 dark:border-ink-700 dark:bg-ink-800 dark:text-ink-200 dark:hover:border-accent-400 dark:hover:text-accent-300 inline-flex items-center rounded-full border bg-white px-3 py-1.5 font-mono text-sm font-medium tabular-nums transition"
                >
                  {y}
                </a>
              </li>
            ))
          }
          <li>
            <button
              id="surprise-btn"
              type="button"
              data-min={SITE.yearMin}
              data-max={SITE.yearMax}
              class="border-accent-200 bg-accent-50 text-accent-800 hover:border-accent-700 hover:bg-accent-100 inline-flex items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm font-medium transition"
              aria-label="Відкрити випадковий рік"
            >
              <span aria-hidden="true" class="text-accent-700 font-display">※</span>
              Випадковий рік
            </button>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const btn = document.getElementById("surprise-btn");
      if (!(btn instanceof HTMLButtonElement)) return;
      btn.addEventListener("click", function () {
        const min = Number(btn.dataset.min);
        const max = Number(btn.dataset.max);
        if (!Number.isInteger(min) || !Number.isInteger(max) || max < min) return;
        const year = Math.floor(Math.random() * (max - min + 1)) + min;
        window.location.href = `/${year}/`;
      });
    })();
  </script>

  <section class="container-prose mt-20">
    <h2 class="font-display text-ink-900 dark:text-ink-50 text-xl font-bold">Як це працює</h2>
    <ol class="text-ink-700 dark:text-ink-200 mt-4 space-y-3">
      <li>
        <span class="text-ink-900 dark:text-ink-50 font-semibold">1. Введи рік випуску.</span> Від 1991
        до сьогодні.
      </li>
      <li>
        <span class="text-ink-900 dark:text-ink-50 font-semibold">2. Отримаєш стрічку оновлень</span
        >
        по 5 предметах: астрономія, біологія, географія, історія, фізика. Те, що змінилось у науці й світі
        від твого випускного року.
      </li>
      <li>
        <span class="text-ink-900 dark:text-ink-50 font-semibold">3. Кожен факт — з джерелом.</span>
        Можна розгорнути деталі в науково-популярному форматі.
      </li>
    </ol>
  </section>

  <section class="container-prose mt-16">
    <h2 class="font-display text-ink-900 dark:text-ink-50 text-xl font-bold">Тематичні блоки</h2>
    <ul class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-5">
      {
        SUBJECTS.map((s) => (
          <li class="border-ink-100 dark:border-ink-700 dark:bg-ink-800 flex flex-col items-start rounded-2xl border bg-white p-4">
            <span class="text-accent-700 dark:text-accent-300 font-display text-2xl font-bold tracking-[0.18em]">
              {s.mark}
            </span>
            <span class="text-ink-900 dark:text-ink-100 mt-2 font-medium">{s.label}</span>
          </li>
        ))
      }
    </ul>
    <p class="text-ink-500 dark:text-ink-400 mt-4 text-sm">
      Зараз у базі: <span class="text-ink-700 dark:text-ink-200 font-semibold">{totalFacts}</span>{
        " "
      }
      {totalFacts === 1 ? "факт" : "фактів"}. Поповнюємо постійно.
    </p>
  </section>
</Base>
