---
// /en/all/ — scaffold mirror of the UK `/all/` index. The English shell
// surfaces the count and links to the full Ukrainian list. Full English
// per-fact pages are deferred to roadmap 9.3.
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { SITE, SUBJECTS } from "../../config/site";
import { getT } from "../../i18n/t";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const t = getT("en");
const totalFacts = allFacts.length;

const bySubject: Record<string, number> = {};
for (const subject of SUBJECTS) {
  bySubject[subject.id] = allFacts.filter((f) => f.data.subject === subject.id).length;
}
---

<Base title={t("nav.all")}>
  <div class="container-prose pt-16 pb-20">
    <span class="font-mono text-[11px] tracking-[0.14em] text-[color:var(--muted)] uppercase">
      {SITE.name} · all facts
    </span>
    <h1
      class="font-display mt-3 text-[clamp(2rem,5vw,3.5rem)] leading-tight font-extrabold tracking-[-0.03em] text-[color:var(--ink)]"
    >
      {t("nav.all")}
    </h1>
    <p class="mt-5 max-w-prose text-lg leading-relaxed text-[color:var(--ink-2)]">
      The full database holds <strong class="tabular-nums">{totalFacts}</strong>
      facts across {SUBJECTS.length} subjects, {SITE.yearMin}—today.
    </p>

    <div
      class="mt-8 rounded-sm border border-l-4 border-[color:var(--card-edge)] border-l-[color:var(--accent)] bg-[color:var(--card)] p-5 text-sm leading-relaxed text-[color:var(--ink-2)]"
      role="note"
    >
      <strong class="font-display block text-base font-semibold text-[color:var(--ink)]">
        {t("scaffold.banner.title")}
      </strong>
      <p class="mt-1">{t("scaffold.banner.body")}</p>
      <p class="mt-3">
        <a
          href="/all/"
          class="font-mono text-[11px] tracking-[0.08em] text-[color:var(--accent)] uppercase underline-offset-2 hover:underline"
        >
          → Browse the full Ukrainian list
        </a>
      </p>
    </div>

    <section class="mt-12">
      <h2
        class="font-display text-[clamp(1.25rem,3vw,1.75rem)] font-bold tracking-tight text-[color:var(--ink)]"
      >
        Facts by subject
      </h2>
      <ul class="mt-4 grid gap-3 sm:grid-cols-2">
        {
          SUBJECTS.map((subject) => (
            <li class="flex items-baseline justify-between gap-3 rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] px-4 py-3">
              <span class="font-display text-base font-semibold text-[color:var(--ink)]">
                <span aria-hidden="true">{subject.emoji}</span> {subject.id}
              </span>
              <span class="font-mono text-xs text-[color:var(--muted)] tabular-nums">
                {bySubject[subject.id] ?? 0}
              </span>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>
