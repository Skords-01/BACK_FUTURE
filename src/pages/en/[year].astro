---
// /en/[year]/ — scaffold for each graduation year. Static-generates the
// full {yearMin..yearMax} range so every UK `/[year]/` has an `/en/[year]/`
// mirror with `<html lang="en">` and the hreflang relation populated by
// `Base.astro`. The English page itself is intentionally lightweight: it
// surfaces counters and links to the rich Ukrainian view. Full English
// year-page (facts, ThenAside, FactTimeline) is roadmap 9.3.
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import { factsForYear, type Fact } from "../../lib/filterFacts";
import { eraOf } from "../../lib/eras";
import { SITE } from "../../config/site";
import { getT } from "../../i18n/t";

export async function getStaticPaths() {
  const years: { params: { year: string } }[] = [];
  for (let y = SITE.yearMin; y <= SITE.yearMax; y++) {
    years.push({ params: { year: String(y) } });
  }
  return years;
}

const { year: yearStr } = Astro.params;
const year = Number(yearStr);
if (!Number.isInteger(year) || year < SITE.yearMin || year > SITE.yearMax) {
  return Astro.redirect("/en/");
}

const allFacts = await getCollection("facts");
const matched: Fact[] = factsForYear(allFacts, year);
const era = eraOf(year);
const totalCount = matched.length;
const yearNow = new Date().getFullYear();
const yearsPassed = yearNow - year;

const t = getT("en");
const titlePrefix = t("page.year.title_prefix");
const title = `${titlePrefix} ${year}`;
const description = `Class of ${year}: ${totalCount} updates since you closed your textbook. ${SITE.name} (English shell).`;
const ogImage = new URL(`/og/${year}.png`, SITE.defaultUrl).toString();

const articleLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  inLanguage: "en",
  url: new URL(`/en/${year}/`, SITE.defaultUrl).toString(),
  description,
};
---

<Base title={title} description={description} ogImage={ogImage} jsonLd={articleLd}>
  <section class="container-prose pt-16 pb-12">
    <p
      class="text-accent-700 dark:text-accent-300 mb-3 inline-flex items-center gap-2 text-sm font-medium tracking-widest uppercase"
    >
      <span
        class="bg-accent-50 text-accent-700 dark:bg-accent-900/40 dark:text-accent-200 rounded-full px-3 py-1 font-mono text-xs tabular-nums"
      >
        {year}
      </span>
      <span>{titlePrefix}</span>
    </p>

    <h1
      class="font-display text-ink-900 text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-6xl"
      data-reveal
    >
      Class of {year}
    </h1>

    <p class="text-ink-700 mt-5 max-w-prose text-lg leading-relaxed sm:text-xl">
      <strong class="tabular-nums">{totalCount}</strong> updates since you finished school — across science,
      history, and the world over the past
      <strong class="tabular-nums">{yearsPassed}</strong> years.
    </p>

    {
      era && (
        <p class="mt-4 max-w-prose text-sm text-[color:var(--ink-2)]">
          Your school era: <strong>{era.label}</strong> ({era.yearStart}—{era.yearEnd}).
        </p>
      )
    }

    <div
      class="mt-10 rounded-sm border border-l-4 border-[color:var(--card-edge)] border-l-[color:var(--accent)] bg-[color:var(--card)] p-5 text-sm leading-relaxed text-[color:var(--ink-2)]"
      role="note"
    >
      <strong class="font-display block text-base font-semibold text-[color:var(--ink)]">
        {t("scaffold.banner.title")}
      </strong>
      <p class="mt-1">{t("scaffold.banner.body")}</p>
      <p class="mt-3">
        <a
          href={`/${year}/`}
          class="font-mono text-[11px] tracking-[0.08em] text-[color:var(--accent)] uppercase underline-offset-2 hover:underline"
        >
          → Read the full Ukrainian feed for {year}
        </a>
      </p>
    </div>

    <div class="mt-10 flex flex-wrap items-center gap-3">
      <a
        href="/en/"
        class="text-ink-500 hover:text-ink-900 dark:text-ink-400 dark:hover:text-ink-900 inline-flex items-center gap-1 text-sm underline-offset-2 hover:underline"
      >
        ← {t("nav.home")}
      </a>
      <a
        href={`/${year}/`}
        class="inline-flex items-center gap-2 rounded-sm border border-[color:var(--accent)] bg-transparent px-4 py-2 font-mono text-sm font-semibold text-[color:var(--accent)] transition hover:bg-[color:var(--accent)] hover:text-white"
      >
        Full UA view →
      </a>
    </div>
  </section>
</Base>
