---
import Base from "../../layouts/Base.astro";
import { SITE, SUBJECTS } from "../../config/site";
import { getCollection } from "astro:content";
import { getT } from "../../i18n/t";

const allFacts = await getCollection("facts", ({ data }) => !data.draft);
const factsCount = allFacts.length;
const t = getT("en");
---

<Base title={t("page.about.title")}>
  <div class="container-prose pt-16">
    <span class="font-mono text-[11px] tracking-[0.14em] text-[color:var(--muted)] uppercase">
      {SITE.name} · about us
    </span>

    <h1
      class="font-display mt-3 text-[clamp(2rem,5vw,3.5rem)] leading-tight font-extrabold tracking-[-0.03em] text-[color:var(--ink)]"
      data-reveal
    >
      {t("page.about.title")}
    </h1>

    <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4" data-reveal>
      {
        (
          [
            { n: String(factsCount), l: "facts in the base" },
            { n: String(SUBJECTS.length), l: "school subjects" },
            { n: "5", l: "school eras" },
            { n: `${SITE.yearMin}–${SITE.yearMax}`, l: "years covered" },
          ] as { n: string; l: string }[]
        ).map((stat) => (
          <div class="rounded-sm border border-[color:var(--card-edge)] bg-[color:var(--card)] p-4">
            <div class="font-display text-[clamp(1.75rem,4vw,2.25rem)] leading-none font-extrabold text-[color:var(--accent)] tabular-nums">
              {stat.n}
            </div>
            <div class="mt-1.5 font-mono text-[10px] tracking-wider text-[color:var(--muted)] uppercase">
              {stat.l}
            </div>
          </div>
        ))
      }
    </div>

    <div
      class="mt-10 rounded-sm border border-l-4 border-[color:var(--card-edge)] border-l-[color:var(--accent)] bg-[color:var(--card)] p-5 text-sm leading-relaxed text-[color:var(--ink-2)]"
      role="note"
    >
      <strong class="font-display block text-base font-semibold text-[color:var(--ink)]">
        {t("scaffold.banner.title")}
      </strong>
      <p class="mt-1">{t("scaffold.banner.body")}</p>
      <p class="mt-3">
        <a
          href="/about/"
          class="font-mono text-[11px] tracking-[0.08em] text-[color:var(--accent)] uppercase underline-offset-2 hover:underline"
        >
          → Full Ukrainian about page
        </a>
      </p>
    </div>

    <div
      class="prose prose-ink prose-headings:font-display dark:prose-invert text-ink-800 dark:text-ink-700 mt-12 max-w-none"
    >
      <p data-reveal>
        BACK_FUTURE is a Ukrainian educational project for adults who finished school between {
          SITE.yearMin
        } and today. Type your graduation year and receive a curated feed of what changed in science,
        history, and the world since.
      </p>
      <p data-reveal>
        The content is written in Ukrainian and reviewed against the school curriculum for each of {
          SUBJECTS.length
        } subjects. The English UI is a structural shell — facts themselves stay in their source language
        until a dedicated translation phase ships.
      </p>
      <p data-reveal>
        Want the full picture? Use the Ukrainian version: it has the year picker, density strip, the
        five eras, all {factsCount} facts, the quiz, and the search.
      </p>
    </div>
  </div>
</Base>
