---
import "../styles/global.css";
import { SITE } from "../config/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";
import RevealObserver from "../components/RevealObserver.astro";
import ScrollRestore from "../components/ScrollRestore.astro";
import {
  DEFAULT_LOCALE,
  LOCALES,
  LOCALE_HTML_LANG,
  LOCALE_OG_LOCALE,
  type Locale,
} from "../i18n/ui";
import { getT, toLocale } from "../i18n/t";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const defaultOgImage = new URL("/og/default.png", SITE.defaultUrl).toString();
const {
  title,
  description = SITE.description,
  ogImage = defaultOgImage,
  jsonLd,
  noindex = false,
} = Astro.props;

// Локаль визначаємо за URL — це джерело правди для статичних сторінок під
// `/en/*`. `Astro.currentLocale` теж доступний (з i18n-конфігу), але шлях
// надійніший для special-cases як 404 чи статичні редиректи. Якщо у
// майбутньому з'являться додаткові локалі — оновити `enPrefix` на map.
const pathname = Astro.url.pathname;
const enPrefix = "/en";
const isEnPath = pathname === enPrefix || pathname.startsWith(`${enPrefix}/`);
const astroLocale = toLocale(Astro.currentLocale);
const locale: Locale = astroLocale === "en" || isEnPath ? "en" : DEFAULT_LOCALE;
const t = getT(locale);

const fullTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(pathname, SITE.defaultUrl).toString();
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Обчислюємо «канонічний UK-шлях» — однаковий для обох локалей. Звідти
// будуємо `hreflang`-альтернативи. Trailing slash зберігаємо, бо `format:
// directory` у Astro фіксує `/about/`.
const ukPath: string =
  pathname.startsWith(`${enPrefix}/`) || pathname === enPrefix
    ? pathname.slice(enPrefix.length) || "/"
    : pathname;
const enPath: string = ukPath === "/" ? `${enPrefix}/` : `${enPrefix}${ukPath}`;
const ukHref = new URL(ukPath, SITE.defaultUrl).toString();
const enHref = new URL(enPath, SITE.defaultUrl).toString();
const alternateHrefs: { hreflang: string; href: string }[] = [
  { hreflang: "uk", href: ukHref },
  { hreflang: "en", href: enHref },
  // `x-default` — uk як «основна» локаль для пошуковиків без явної переваги.
  { hreflang: "x-default", href: ukHref },
];
const alternateOgLocales: string[] = LOCALES.filter((l) => l !== locale).map(
  (l) => LOCALE_OG_LOCALE[l],
);

// Опційні токени верифікації пошуковців для Search Console / Bing Webmaster.
// Якщо змінна не задана — meta-тег не рендериться.
const googleSiteVerification = import.meta.env.GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.BING_SITE_VERIFICATION;

// Безпечна серіалізація для embed у <script>: екрануємо `<` щоб не зламатись
// на потенційному `</script>` усередині рядкових значень.
const serializeJsonLd = (data: Record<string, unknown>): string =>
  JSON.stringify(data).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang={LOCALE_HTML_LANG[locale]} data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    {/* prettier-ignore */}
    <script is:inline>
      // Pre-paint: вирішуємо тему до першого рендеру щоб не мерехтіло.
      (function () {
        try {
          var stored = window.localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var isDark = stored === "dark" || (stored !== "light" && prefersDark);
          if (isDark) document.documentElement.classList.add("dark");
        } catch {
          // localStorage / matchMedia недоступні — нічого не робимо.
        }
      })();
    </script>
    {/* prettier-ignore */}
    <script is:inline>
      // First-visit locale heuristic (roadmap 9.1 improvement): якщо
      // користувач ще не висловив явну преференцію (через LangSwitcher,
      // який пише `bf_lang` у localStorage), і потрапив на UK-сторінку з
      // браузером, що повідомляє `navigator.language` починаючи з `en`, —
      // мовчки редіректимо на EN-мірор. Один-разовий редирект, далі
      // користувач рулить через перемикач.
      (function () {
        try {
          var path = window.location.pathname || "/";
          if (path.indexOf("/en") === 0) return; // вже на EN — не чіпаємо.
          var explicit = window.localStorage.getItem("bf_lang");
          if (explicit) return; // вибір зроблено — поважаємо.
          var lang = (navigator.language || "").toLowerCase();
          if (lang.indexOf("en") !== 0) return; // не англомовний — лишаємось.
          // Будуємо EN-аналог поточного шляху.
          var target = path === "/" ? "/en/" : "/en" + path;
          // Зберігаємо щоб редирект не повторювався у нескінченному циклі
          // у разі, якщо EN-сторінка чомусь редіректить назад.
          window.localStorage.setItem("bf_lang", "en");
          window.location.replace(target + window.location.search + window.location.hash);
        } catch {
          // localStorage / navigator недоступні — нічого не робимо.
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {
      import.meta.env.SENTRY_DSN && (
        <link rel="dns-prefetch" href="https://browser.sentry-cdn.com" />
      )
    }
    {
      googleSiteVerification && (
        <meta name="google-site-verification" content={googleSiteVerification} />
      )
    }
    {bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {alternateHrefs.map((alt) => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={LOCALE_OG_LOCALE[locale]} />
    {
      alternateOgLocales.map((altLocale) => (
        <meta property="og:locale:alternate" content={altLocale} />
      ))
    }
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {SITE.twitter && <meta name="twitter:site" content={`@${SITE.twitter}`} />}
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="preload"
      href="/fonts/geist-cyrillic-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/geist-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      /* Display-шрифт для h1/h2/h3 — без preload браузер чекає
       парсингу CSS і ставить FOUT поверх вже намальованого тіла.
       31 KB кирилиці — найдешевша заявка на стабільний first paint. */
    }
    <link
      rel="preload"
      href="/fonts/unbounded-cyrillic-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={serializeJsonLd(item)} />
      ))
    }
    <Analytics />
  </head>
  <body class="bg-paper-50 text-ink-900 font-sans">
    <a href="#main-content" class="skip-link">{t("site.skip_link")}</a>
    <Header />
    <main id="main-content" tabindex="-1" class="pb-24" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <RevealObserver />
    <ScrollRestore />
  </body>
</html>
