---
import "../styles/global.css";
import { SITE } from "../config/site";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Analytics from "../components/Analytics.astro";
import RevealObserver from "../components/RevealObserver.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const defaultOgImage = new URL("/og/default.png", SITE.defaultUrl).toString();
const { title, description = SITE.description, ogImage = defaultOgImage, jsonLd, noindex = false } = Astro.props;
const fullTitle = title ? `${title} — ${SITE.name}` : `${SITE.name} — ${SITE.tagline}`;
const canonical = new URL(Astro.url.pathname, SITE.defaultUrl).toString();
const jsonLdItems = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];

// Опційні токени верифікації пошуковців для Search Console / Bing Webmaster.
// Якщо змінна не задана — meta-тег не рендериться.
const googleSiteVerification = import.meta.env.GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.BING_SITE_VERIFICATION;

// Безпечна серіалізація для embed у <script>: екрануємо `<` щоб не зламатись
// на потенційному `</script>` усередині рядкових значень.
const serializeJsonLd = (data: Record<string, unknown>): string =>
  JSON.stringify(data).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    {/* prettier-ignore */}
    <script is:inline>
      // Pre-paint: вирішуємо тему до першого рендеру щоб не мерехтіло.
      (function () {
        try {
          var stored = window.localStorage.getItem("theme");
          var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var isDark = stored === "dark" || (stored !== "light" && prefersDark);
          if (isDark) document.documentElement.classList.add("dark");
        } catch {
          // localStorage / matchMedia недоступні — нічого не робимо.
        }
      })();
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    {import.meta.env.SENTRY_DSN && <link rel="dns-prefetch" href="https://browser.sentry-cdn.com" />}
    {
      googleSiteVerification && (
        <meta name="google-site-verification" content={googleSiteVerification} />
      )
    }
    {bingSiteVerification && <meta name="msvalidate.01" content={bingSiteVerification} />}
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="uk_UA" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {SITE.twitter && <meta name="twitter:site" content={`@${SITE.twitter}`} />}
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="preload"
      href="/fonts/geist-cyrillic-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/geist-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {
      jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={serializeJsonLd(item)} />
      ))
    }
    <Analytics />
  </head>
  <body class="bg-paper-50 text-ink-900 font-sans">
    <a href="#main-content" class="skip-link">Перейти до контенту</a>
    <Header />
    <main id="main-content" tabindex="-1" class="pb-24" data-pagefind-body>
      <slot />
    </main>
    <Footer />
    <RevealObserver />
  </body>
</html>
